{
  "name": "nestandnook-site",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "audit:readiness": "node scripts/site-readiness-audit.mjs",
    "audit:readiness:strict": "node scripts/site-readiness-audit.mjs --strict",
    "test:tools": "node --test tests/tools/*.test.mjs",
    "build": "npm run audit:readiness && npm run test:tools && astro build && pagefind --site dist --output-subdir pagefind",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^4.15.0",
    "pagefind": "^1.5.2"
  }
}
