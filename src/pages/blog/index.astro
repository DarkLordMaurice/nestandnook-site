---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config.ts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => +b.data.publishDate - +a.data.publishDate);
---
<BaseLayout
  title={`Winnie's Notes — ${SITE.brand}`}
  description="Winnie Hollowell's take on the small fixes, favorite finds, and slice-of-life stuff behind Nest & Nook."
  showDisclosure={false}
>
  <section class="hero">
    <span class="washi washi-pink">Notes from the nook</span>
    <h1>Winnie's Notes</h1>
    <p class="lede">The running commentary — my honest reactions, the fixes I'd tell a neighbor about over the fence, and the occasional detour into whatever's making my nook happy this week.</p>
  </section>

  <section class="hero-banner hero-banner-single">
    <div class="hero-banner-inner">
      <div class="polaroid tilt-left">
        <img src="/winnie/scrapbook-desk.jpg" alt="Winnie sorting through a desk full of clippings and photos" class="hero-photo" width="800" height="450" />
      </div>
    </div>
  </section>

  {posts.length === 0 ? (
    <p><em>First notes publishing soon.</em></p>
  ) : (
    <ul class="guide-grid post-grid">
      {posts.map((p) => (
        <li class="guide-card post-card">
          <a href={`/blog/${p.slug}/`} class="post-card-image-link">
            <img src={p.data.image} alt="" class="post-card-image" width="500" height="300" />
          </a>
          <span class="eyebrow">{p.data.category}</span>
          <a class="title-link" href={`/blog/${p.slug}/`}>{p.data.title}</a>
          <p>{p.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
