---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import HeroCollage from '../../components/HeroCollage.astro';
import { SITE } from '../../config.ts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => +b.data.publishDate - +a.data.publishDate);
---
<BaseLayout
  title={`Winnie's Notes — ${SITE.brand}`}
  description="Winnie Hollowell's take on the small fixes, favorite finds, and slice-of-life stuff behind Nest & Nook."
  showDisclosure={false}
>
  <section class="hero-banner hero-banner-collage">
    <div class="hero-banner-inner">
      <div>
        <span class="washi washi-pink">Notes from the nook</span>
        <h1>Winnie's Notes</h1>
        <p class="lede">The running commentary — my honest reactions, the fixes I'd tell a neighbor about over the fence, and the occasional detour into whatever's making my nook happy this week.</p>
      </div>
      <HeroCollage
        anchor={{ src: '/winnie/scrapbook-desk.jpg', alt: 'Winnie sorting through a desk full of clippings and photos', tilt: 'left' }}
        accents={[
          { src: '/winnie/winnie-life-bookstore.jpg', alt: 'Winnie browsing shelves at a used bookstore', tilt: 'right' },
        ]}
      />
    </div>
  </section>

  {posts.length === 0 ? (
    <p><em>First notes publishing soon.</em></p>
  ) : (
    <div class="masonry">
      {posts.map((p, i) => (
        <BlogCard
          href={`/blog/${p.slug}/`}
          image={p.data.image}
          title={p.data.title}
          description={p.data.description}
          category={p.data.category}
          featured={i === 0}
        />
      ))}
    </div>
  )}
</BaseLayout>
