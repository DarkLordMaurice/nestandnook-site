---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WinnieByline from '../../components/WinnieByline.astro';
import WinniePendingPhoto from '../../components/WinniePendingPhoto.astro';
import { SITE } from '../../config.ts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

// Winnie is deliberately NOT typed as schema.org Person here — same rationale
// as BaseLayout.astro: she's disclosed sitewide as a fully virtual,
// AI-generated host, not a real individual, so Organization is the honest
// authorship type for her byline (matches the pattern used on review/recipe
// pages, which credit "Nest & Nook Editorial"/"Kitchen Team" as Organization).
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.description,
  datePublished: d.publishDate,
  dateModified: d.updatedDate ?? d.publishDate,
  author: { '@type': 'Organization', name: "Nest & Nook Editorial", url: `${SITE.url}/about/` },
  publisher: { '@type': 'Organization', name: SITE.brand },
};
---
<BaseLayout title={d.title} description={d.description} ogImage={d.ogImage} jsonLd={jsonLd} showDisclosure={false}>
  <div class="prose">
    <div class="article-hero-band">
      <div class="article-hero-text">
        <span class="washi washi-pink">{d.category}</span>
        <h1>{d.title}</h1>
      </div>
    </div>

    {d.image === 'PENDING' ? (
      <WinniePendingPhoto />
    ) : (
      <figure class="inline-photo hero-photo">
        <img src={d.image} alt="Winnie Hollowell" loading="eager" fetchpriority="high" style={d.imagePosition ? `--img-pos: ${d.imagePosition}` : undefined} />
      </figure>
    )}

    <WinnieByline photo={d.winniePhoto} />

    <Content />

    {d.relatedGuides.length > 0 && (
      <nav class="related">
        <h2>Related guides</h2>
        <ul>{d.relatedGuides.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </nav>
    )}
  </div>
</BaseLayout>
