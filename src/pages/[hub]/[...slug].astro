---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BestForDecisionTable from '../../components/BestForDecisionTable.astro';
import HowWeChoose from '../../components/HowWeChoose.astro';
import LastReviewed from '../../components/LastReviewed.astro';
import { SITE, amazonLink } from '../../config.ts';
import { DEFAULT_AUTHOR } from '../../authors.ts';
import { HUBS } from '../../hubs.ts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((entry) => ({
    params: { hub: entry.data.hub, slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const authorName = DEFAULT_AUTHOR.name;
const canonical = `${SITE.url}/${d.hub}/${entry.slug}/`;
const reviewDate = d.updatedDate ?? d.publishDate;
const heroAlt = d.imageAlt ?? `Winnie Hollowell illustrating ${d.primaryKeyword} in a practical small-space ${d.hub === 'kitchen' ? 'kitchen' : 'home office'} setup.`;
const heroCaption = d.imageCaption ?? `An illustrative Winnie Hollowell scene showing the small-space problem addressed in this guide; it does not represent hands-on testing of a branded product.`;

const articleSchema = {
  '@type': 'Article',
  '@id': `${canonical}#article`,
  headline: d.title,
  description: d.description,
  datePublished: d.publishDate,
  dateModified: reviewDate,
  mainEntityOfPage: canonical,
  author: { '@type': 'Person', name: authorName, url: `${SITE.url}/about/` },
  publisher: { '@id': `${SITE.url}/#organization` },
  ...(d.image && { image: [`${SITE.url}${d.image}`] }),
};

const itemListSchema = d.products.length > 0 ? {
  '@type': 'ItemList',
  '@id': `${canonical}#recommendations`,
  name: `${d.title} recommendations`,
  numberOfItems: d.products.length,
  itemListElement: d.products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: amazonLink(p.asin),
  })),
} : null;

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  '@id': `${canonical}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: HUBS[d.hub]?.name ?? d.hub, item: `${SITE.url}/${d.hub}/` },
    { '@type': 'ListItem', position: 3, name: d.title, item: canonical },
  ],
};

const faqSchema = d.faqs.length > 0 ? {
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  mainEntity: d.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [articleSchema, breadcrumbSchema, ...(itemListSchema ? [itemListSchema] : []), ...(faqSchema ? [faqSchema] : [])],
};
---
<BaseLayout
  title={d.title}
  description={d.description}
  ogImage={d.ogImage ?? d.image}
  jsonLd={jsonLd}
  author={authorName}
  bylineLabel="Edited by"
  publishDate={d.publishDate}
  updatedDate={d.updatedDate}
>
  <article class="prose">
    <div class="article-hero-band">
      <div class="article-hero-text">
        <span class="washi">{HUBS[d.hub]?.name ?? d.hub}</span>
        <h1>{d.title}</h1>
      </div>
      {d.image && (
        <figure class="article-hero-photo-inset">
          <div class="article-hero-photo-card">
            <img src={d.image} alt={heroAlt} loading="eager" fetchpriority="high" style={d.imagePosition ? `--img-pos: ${d.imagePosition}` : undefined} />
          </div>
          <figcaption>{heroCaption}</figcaption>
        </figure>
      )}
    </div>

    <BestForDecisionTable products={d.products} />

    <Content />

    {d.products.length > 0 && (
      <section id="product-recommendations" aria-labelledby="product-recommendations-heading">
        <h2 id="product-recommendations-heading">Product recommendations</h2>
        {d.products.map((p) => (
          <ProductCard
            name={p.name}
            asin={p.asin}
            bestFor={p.bestFor}
            blurb={p.blurb}
            pros={p.pros}
            cons={p.cons}
            lookFor={p.lookFor}
            skipIf={p.skipIf}
            smallSpaceNote={p.smallSpaceNote}
            image={p.image}
            winnieImage={p.winnieImage}
          />
        ))}
      </section>
    )}

    {d.internalLinks.length > 0 && (
      <nav class="related" id="related-small-space-problems" aria-label="Related guides">
        <h2>Related guides</h2>
        <ul>{d.internalLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </nav>
    )}

    <HowWeChoose hub={d.hub} pageType={d.pageType} productCount={d.products.length} />
    <LastReviewed date={reviewDate} />
  </article>

  <style>
    .article-hero-photo-inset { margin: 0; }
    .article-hero-photo-inset figcaption {
      margin-top: 0.45rem;
      font-size: 0.76rem;
      line-height: 1.35;
      color: #e9e0cd;
      max-width: 36rem;
    }
  </style>
</BaseLayout>
