---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config.ts';
import { HUBS } from '../../hubs.ts';
import { getCollection } from 'astro:content';

// Hub landing pages (/home-office/, /kitchen/). Fixes the header nav targets
// and acts as a light pillar hub that links to every guide in the hub.
// HUBS lives in its own module (src/hubs.ts) so it's reliably available to
// both getStaticPaths and this render scope during the static build.

export async function getStaticPaths() {
  return Object.keys(HUBS).map((hub) => ({ params: { hub } }));
}

const { hub } = Astro.params;
const meta = HUBS[hub as string];
const reviews = (await getCollection('reviews')).filter((r) => r.data.hub === hub);
reviews.sort((a, b) => +b.data.publishDate - +a.data.publishDate);
---
<BaseLayout
  title={`${meta.name} — ${SITE.brand}`}
  description={meta.blurb}
  showDisclosure={false}
>
  <h1>{meta.name}</h1>
  <p>{meta.blurb}</p>

  <h2>Guides</h2>
  {reviews.length === 0 ? (
    <p><em>Guides publishing soon.</em></p>
  ) : (
    <ul>
      {reviews.map((r) => (
        <li><a href={`/${r.data.hub}/${r.slug}/`}>{r.data.title}</a></li>
      ))}
    </ul>
  )}
</BaseLayout>
