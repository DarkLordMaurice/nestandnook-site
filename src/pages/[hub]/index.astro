---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WinnieNote from '../../components/WinnieNote.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import SideRail from '../../components/SideRail.astro';
import { SITE } from '../../config.ts';
import { HUBS } from '../../hubs.ts';
import { getCollection } from 'astro:content';

// Hub landing pages (/home-office/, /kitchen/). Fixes the header nav targets
// and acts as a light pillar hub that links to every guide in the hub.
// HUBS lives in its own module (src/hubs.ts) so it's reliably available to
// both getStaticPaths and this render scope during the static build.

export async function getStaticPaths() {
  return Object.keys(HUBS).map((hub) => ({ params: { hub } }));
}

const { hub } = Astro.params;
const meta = HUBS[hub as string];
const reviews = (await getCollection('reviews')).filter((r) => r.data.hub === hub);
reviews.sort((a, b) => +b.data.publishDate - +a.data.publishDate);

const otherHubKey = Object.keys(HUBS).find((k) => k !== hub);
const otherHub = otherHubKey ? HUBS[otherHubKey] : null;
---
<BaseLayout
  title={`${meta.name} — ${SITE.brand}`}
  description={meta.blurb}
  showDisclosure={false}
>
  <SideRail
    heading="Explore more"
    links={[
      ...(otherHub && otherHubKey ? [{ label: otherHub.name, href: `/${otherHubKey}/` }] : []),
      { label: 'Recipes', href: '/recipes/' },
      { label: "Winnie's Notes", href: '/blog/' },
      { label: 'About Winnie', href: '/about/' },
    ]}
  />
  <section class="hero">
    <span class="washi">{meta.name}</span>
    <h1>{meta.name}</h1>
    <p class="lede">{meta.blurb}</p>
  </section>

  <section class="hero-banner hero-banner-single">
    <div class="hero-banner-inner">
      <div class="polaroid tilt-right">
        <img src={meta.hero} alt={meta.heroAlt} class="hero-photo" width="800" height="450" />
      </div>
    </div>
  </section>

  <WinnieNote photo={meta.winniePhoto}>
    <p>{meta.winnieIntro}</p>
  </WinnieNote>

  <h2>Guides</h2>
  {reviews.length === 0 ? (
    <p><em>Guides publishing soon.</em></p>
  ) : (
    <div class="masonry">
      {reviews.map((r, i) => (
        <ReviewCard
          href={`/${r.data.hub}/${r.slug}/`}
          image={r.data.image ?? meta.hero}
          title={r.data.title}
          description={r.data.description}
          pageType={r.data.pageType}
          featured={i === 0}
        />
      ))}
    </div>
  )}
</BaseLayout>
