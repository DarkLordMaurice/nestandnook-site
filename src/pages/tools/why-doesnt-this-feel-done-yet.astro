---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WinnieNote from '../../components/WinnieNote.astro';
import ToolScene from '../../components/tools/ToolScene.astro';
import { SITE } from '../../config';
import { TOOLS } from '../../data/tools';
import { QUESTIONS } from '../../lib/tools/why-doesnt-this-feel-done-yet.mjs';
import '../../styles/tools.css';

const tool = TOOLS.find((item) => item.slug === 'why-doesnt-this-feel-done-yet')!;
const canonical = `${SITE.url}${tool.href}`;
const jsonLd = {
  '@context': 'https://schema.org', '@graph': [
    { '@type': 'WebApplication', '@id': `${canonical}#tool`, name: tool.title, description: tool.description, url: canonical, applicationCategory: 'UtilitiesApplication', operatingSystem: 'Any', isAccessibleForFree: true, publisher: { '@id': `${SITE.url}/#organization` } },
    { '@type': 'BreadcrumbList', '@id': `${canonical}#breadcrumb`, itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: `${SITE.url}/tools/` },
      { '@type': 'ListItem', position: 3, name: tool.title, item: canonical },
    ] },
  ],
};
---
<BaseLayout title={`${tool.title} — ${SITE.brand}`} description={tool.description} showDisclosure={false} jsonLd={jsonLd}>
  <article class="tool-page">
    <div class="article-hero-band">
      <div class="article-hero-text">
        <span class="washi washi-teal">{tool.eyebrow}</span>
        <h1>{tool.title}</h1>
      </div>
    </div>
    <ToolScene slug={tool.slug} />

    <p id="quick-answer" class="lede tool-lede">Five questions about the one room that still bugs you. Not a personality type — an actual diagnosis, and one specific move to try first.</p>

    <div class="tool-privacy-note" role="note"><strong>No data collected:</strong> this tool runs entirely in your browser. Nest & Nook does not save your answers.</div>

    <WinnieNote photo="/winnie/headshot-v4-1.jpg">
      <p>"Doesn't feel done" is almost never about needing more stuff. It's usually one of four specific things — and once you know which one, the fix is a lot smaller than it feels right now.</p>
    </WinnieNote>

    <div class="tool-layout">
      <section class="tool-panel tool-form-panel" aria-labelledby="quiz-heading">
        <h2 id="quiz-heading">Five questions</h2>
        <div id="quiz-errors" class="tool-errors" role="alert" aria-live="assertive"></div>

        <form id="diagnostic-quiz" class="tool-form quiz-form" novalidate>
          {QUESTIONS.map((q, i) => (
            <fieldset class="quiz-question">
              <legend>{i + 1}. {q.text}</legend>
              <div class="quiz-options">
                {q.options.map((opt) => (
                  <label class="quiz-option">
                    <input type="radio" name={q.id} value={opt.value} required />
                    <span class="quiz-option-label">{opt.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          ))}

          <div class="tool-actions no-print">
            <button class="tool-button" type="submit">Diagnose the room</button>
            <button class="tool-button ghost" type="reset">Start over</button>
          </div>
        </form>
      </section>

      <section id="quiz-result" class="tool-panel tool-result" aria-labelledby="quiz-result-heading" aria-live="polite" tabindex="-1" hidden>
        <span class="tool-result-status" id="result-type-name"></span>
        <h2 id="quiz-result-heading">What's actually going on</h2>

        <p class="quiz-result-mirror" id="result-mirror"></p>

        <div class="tool-metrics">
          <div class="tool-metric"><span>Your advantage here</span><strong id="result-superpower"></strong></div>
          <div class="tool-metric"><span>What's tripping you up</span><strong id="result-kryptonite"></strong></div>
        </div>

        <div class="tool-result-section">
          <h3>Winnie says</h3>
          <p id="result-winnie"></p>
        </div>

        <div class="tool-result-section" id="result-tie-note" hidden>
          <p class="quiz-tie-note" id="result-tie-text"></p>
        </div>

        <div class="tool-result-section">
          <a id="result-cta" class="tool-button" href="#">Where to start</a>
        </div>

        <div class="tool-result-section quiz-share">
          <p class="quiz-share-hook" id="result-share-hook"></p>
          <div class="tool-share-actions">
            <button class="tool-button ghost" id="copy-quiz-result" type="button">Copy your result</button>
            <button class="tool-button ghost" id="download-quiz-card" type="button">Download shareable card</button>
          </div>
          <canvas id="share-canvas" width="1248" height="832" hidden></canvas>
        </div>

        <div class="tool-actions no-print">
          <button class="tool-button secondary" id="retake-quiz" type="button">Diagnose a different room</button>
        </div>
      </section>
    </div>

    <section class="tool-related"><h2>Read next</h2><ul>{tool.relatedGuides.map((guide) => <li><a href={guide.href}>{guide.label}</a></li>)}</ul></section>
  </article>

  <script>
    import { scoreQuiz, validateQuizAnswers } from '../../lib/tools/why-doesnt-this-feel-done-yet.mjs';
    import { renderShareCard, downloadCanvas } from '../../lib/tools/share-card.mjs';

    const form = document.querySelector('#diagnostic-quiz');
    const resultPanel = document.querySelector('#quiz-result');
    const errorsBox = document.querySelector('#quiz-errors');
    const layout = document.querySelector('.tool-layout');

    const text = (id, content) => { const el = document.querySelector(id); if (el) el.textContent = content; };

    let quizStarted = false;
    let currentType = null;
    form?.addEventListener('change', () => {
      if (!quizStarted) { quizStarted = true; window.nnTrack?.('tool_started', { tool_slug: 'why-doesnt-this-feel-done-yet' }); }
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const answers = Object.fromEntries(data.entries());
      const errors = validateQuizAnswers(answers);

      if (errors.length) {
        errorsBox.innerHTML = '<strong>Please answer all questions:</strong>';
        const ul = document.createElement('ul');
        errors.forEach((err) => { const li = document.createElement('li'); li.textContent = err; ul.appendChild(li); });
        errorsBox.appendChild(ul);
        resultPanel.hidden = true;
        errorsBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      errorsBox.innerHTML = '';
      const { type, isTie, tiedWith } = scoreQuiz(answers);
      currentType = type;

      text('#result-type-name', type.name);
      text('#result-mirror', type.mirror);
      text('#result-superpower', type.superpower);
      text('#result-kryptonite', type.kryptonite);
      text('#result-winnie', type.winnieSays);
      text('#result-share-hook', type.shareHook);

      const cta = document.querySelector('#result-cta');
      if (cta) { cta.textContent = type.ctaLabel; cta.href = type.ctaHref; }

      const tieNote = document.querySelector('#result-tie-note');
      if (isTie && tieNote) {
        tieNote.hidden = false;
        text('#result-tie-text', `This room also shows real signs of ${tiedWith.join(' and ')} — worth checking both.`);
      } else if (tieNote) { tieNote.hidden = true; }

      resultPanel.hidden = false;
      layout?.classList.add('has-result');
      resultPanel.focus();

      window.nnTrack?.('tool_completed', { tool_slug: 'why-doesnt-this-feel-done-yet', type: type.id });
    });

    form?.addEventListener('reset', () => {
      errorsBox.innerHTML = '';
      resultPanel.hidden = true;
      layout?.classList.remove('has-result');
      currentType = null;
    });

    document.querySelector('#retake-quiz')?.addEventListener('click', () => {
      form?.reset();
      resultPanel.hidden = true;
      layout?.classList.remove('has-result');
      currentType = null;
      form?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    document.querySelector('#copy-quiz-result')?.addEventListener('click', async () => {
      const typeName = document.querySelector('#result-type-name')?.textContent ?? '';
      const copy = `My space diagnosis: ${typeName}. What's yours? ${window.location.href}`;
      try {
        await navigator.clipboard.writeText(copy);
        text('#copy-quiz-result', 'Copied!');
        window.nnTrack?.('result_saved', { tool_slug: 'why-doesnt-this-feel-done-yet', action: 'copy' });
        setTimeout(() => text('#copy-quiz-result', 'Copy your result'), 1800);
      } catch {
        text('#copy-quiz-result', 'Copy unavailable');
      }
    });

    document.querySelector('#download-quiz-card')?.addEventListener('click', async () => {
      if (!currentType) return;
      const canvas = document.querySelector('#share-canvas');
      if (!canvas) return;
      await renderShareCard(canvas, {
        kicker: 'Space diagnosis',
        headline: currentType.name,
        body: currentType.shareBody,
        footerLine: 'Diagnose your own room at nestandnook.org/tools/',
        frameSrc: '/winnie/cert-frame-why-doesnt-this-feel-done-yet.jpg',
      });
      downloadCanvas(canvas, `nest-and-nook-${currentType.id}.png`);
      window.nnTrack?.('result_saved', { tool_slug: 'why-doesnt-this-feel-done-yet', action: 'download_card' });
    });
  </script>
</BaseLayout>

<style>
  .quiz-form { display: flex; flex-direction: column; gap: 2rem; }

  .quiz-question legend {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .quiz-options { display: flex; flex-direction: column; gap: 0.5rem; }

  .quiz-option {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border, #e5e7eb);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .quiz-option:has(input:checked) {
    border-color: var(--color-accent, #6366f1);
    background: var(--color-accent-light, #eef2ff);
  }

  .quiz-option input[type="radio"] { margin-top: 0.125rem; flex-shrink: 0; accent-color: var(--color-accent, #6366f1); }
  .quiz-option-label { font-size: 0.925rem; line-height: 1.5; }

  .quiz-result-mirror { font-size: 1.05rem; line-height: 1.7; margin-bottom: 1.5rem; }
  .quiz-tie-note { font-size: 0.9rem; color: var(--color-text-muted, #6b7280); font-style: italic; }

  .quiz-share { text-align: center; }
  .quiz-share-hook { font-size: 0.9rem; color: var(--color-text-muted, #6b7280); margin-bottom: 0.75rem; font-style: italic; }
  .tool-share-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
</style>
