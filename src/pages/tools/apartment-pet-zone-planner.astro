---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WinnieNote from '../../components/WinnieNote.astro';
import { SITE } from '../../config';
import { TOOLS } from '../../data/tools';
import '../../styles/tools.css';
import '../../styles/pet-zone-planner-addon.css';

const tool = TOOLS.find((item) => item.slug === 'apartment-pet-zone-planner')!;
const canonical = `${SITE.url}${tool.href}`;
const zones = [
  ['feeding', '🍽️', 'Feeding', 'Meals and bowls'], ['water', '💧', 'Water', 'A separate drinking stop'],
  ['hygiene', '🧹', 'Hygiene', 'Litter, pads, or cleanup'], ['sleep', '🌙', 'Sleep', 'A calm retreat'],
  ['enrichment', '🪀', 'Enrichment', 'Play, scratch, and activity'], ['storage', '🧺', 'Storage', 'Food and daily supplies'],
];
const rooms = [['kitchen', 'Kitchen'], ['living', 'Living room'], ['bedroom', 'Bedroom'], ['bathroom', 'Bathroom'], ['entry', 'Entry']];
const jsonLd = { '@context': 'https://schema.org', '@graph': [
  { '@type': 'WebApplication', '@id': `${canonical}#tool`, name: tool.title, description: tool.description, url: canonical, applicationCategory: 'UtilitiesApplication', operatingSystem: 'Any', isAccessibleForFree: true, publisher: { '@id': `${SITE.url}/#organization` } },
  { '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` }, { '@type': 'ListItem', position: 2, name: 'Tools', item: `${SITE.url}/tools/` }, { '@type': 'ListItem', position: 3, name: tool.title, item: canonical },
  ] },
] };
---
<BaseLayout title={`${tool.title} — ${SITE.brand}`} description={tool.description} showDisclosure={false} jsonLd={jsonLd}>
  <article class="tool-page">
    <div class="article-hero-band"><div class="article-hero-text"><span class="washi washi-teal">{tool.eyebrow}</span><h1>{tool.title}</h1></div></div>
    <p class="lede tool-lede">Choose each pet function, then place it on the apartment map. Winnie’s planner checks separation, traffic, storage, and room overload before the bowls and litter box settle in.</p>
    <div class="tool-privacy-note" role="note"><strong>Private by default:</strong> this planner runs locally in your browser. Nest & Nook does not save or transmit your selections.</div>
    <WinnieNote photo="/winnie/headshot-v4-2.jpg"><p>A tiny home can still have generous pet logic. The trick is giving each routine a proper address instead of asking one crowded corner to do six jobs.</p></WinnieNote>

    <div class="pet-planner-shell">
      <section class="pet-planner-controls" aria-labelledby="planner-controls-heading">
        <h2 id="planner-controls-heading">Build the household profile</h2>
        <div id="tool-errors" class="tool-errors" role="alert" aria-live="assertive"></div>
        <form id="pet-zone-form" novalidate>
          <div class="pet-profile-grid">
            <label>Pet household<select name="species"><option value="cat">Cat</option><option value="dog">Dog</option><option value="both">Cat and dog</option></select></label>
            <label>Apartment layout<select name="homeType"><option value="studio">Studio</option><option value="one-bedroom" selected>One bedroom</option><option value="two-plus">Two or more bedrooms</option></select></label>
          </div>
          <div class="traffic-picker"><strong>Which rooms are high traffic?</strong><br />
            {rooms.map(([value, label]) => <label><input type="checkbox" name="traffic" value={value} checked={value === 'entry' || value === 'living'} /> {label}</label>)}
          </div>
          <div class="traffic-picker"><label><input type="checkbox" name="multiplePets" /> Multiple pets</label><label><input type="checkbox" name="children" /> Children in the home</label></div>
          <h3>1. Pick a zone</h3>
          <div class="zone-palette" role="group" aria-label="Pet zones">
            {zones.map(([value, icon, label, help], index) => <button class="zone-chip" type="button" data-zone={value} aria-pressed={index === 0 ? 'true' : 'false'}><span>{icon}</span><span>{label}<small>{help}</small></span></button>)}
          </div>
          <p><strong>2. Click the room where it belongs.</strong> Repeat until all six zone chips have a room.</p>
          <div class="tool-actions pet-plan-actions"><button class="tool-button" type="submit">Review this pet plan</button><button id="clear-plan" class="tool-button ghost" type="button">Clear map</button></div>
        </form>
      </section>

      <section class="pet-floorplan-wrap" aria-labelledby="floorplan-heading">
        <div class="visual-heading"><span class="visual-kicker">Winnie’s apartment sketch</span><strong id="floorplan-heading">Click rooms to place the selected zone</strong></div>
        <div class="pet-floorplan" aria-label="Interactive apartment floor plan">
          {rooms.map(([value, label]) => <button type="button" class={`pet-room room-${value}`} data-room={value}><strong>{label}</strong><span class="room-zones" data-room-zones={value}></span></button>)}
        </div>
        <p id="placement-status" aria-live="polite">Feeding is selected. Choose its room.</p>
      </section>
    </div>

    <section id="pet-zone-result" class="tool-panel tool-result pet-result" aria-labelledby="result-heading" aria-live="polite" tabindex="-1" hidden>
      <span id="result-status" class="tool-result-status">Result</span><h2 id="result-heading">Your apartment pet-zone plan</h2><p id="result-summary"></p>
      <div class="pet-result-columns"><div><h3>Winnie noticed</h3><ul id="result-noticed"></ul><h3>What is already working</h3><ul id="result-strengths"></ul></div><div><h3>Fix first</h3><ol id="result-priorities"></ol><h3>Avoid</h3><ul id="result-avoid"></ul></div></div>
      <p class="tool-disclaimer">This is a household-layout planning aid, not veterinary, behavioral, accessibility, or building-safety advice. Keep exits, heaters, cords, medication, and cleaning products safely managed, and adapt the plan to the individual pet.</p>
      <div class="tool-actions"><button id="print-result" class="tool-button secondary" type="button">Print plan</button></div>
    </section>
    <section class="tool-related"><h2>Read next</h2><ul>{tool.relatedGuides.map((guide) => <li><a href={guide.href}>{guide.label}</a></li>)}</ul></section>
  </article>

  <script>
    import { evaluatePetZones, validatePetZoneInput } from '../../lib/tools/pet-zone-planner.mjs';
    const zoneNames = { feeding: 'Feeding', water: 'Water', hygiene: 'Hygiene', sleep: 'Sleep', enrichment: 'Enrichment', storage: 'Storage' };
    const zoneIcons = { feeding: '🍽️', water: '💧', hygiene: '🧹', sleep: '🌙', enrichment: '🪀', storage: '🧺' };
    const form = document.querySelector('#pet-zone-form'); const errorsBox = document.querySelector('#tool-errors'); const result = document.querySelector('#pet-zone-result');
    let selectedZone = 'feeding'; let placements = {};
    const list = (selector, items) => { const el = document.querySelector(selector); if (!el) return; el.innerHTML = ''; (items.length ? items : ['No pressure points found in this section.']).forEach((item) => { const li = document.createElement('li'); li.textContent = item; el.appendChild(li); }); };
    const render = () => { document.querySelectorAll('[data-room-zones]').forEach((host) => { host.innerHTML = ''; const room = host.dataset.roomZones; Object.entries(placements).filter(([, placedRoom]) => placedRoom === room).forEach(([zone]) => { const badge = document.createElement('span'); badge.className = `placed-zone zone-${zone}`; badge.textContent = `${zoneIcons[zone]} ${zoneNames[zone]}`; host.appendChild(badge); }); }); };
    document.querySelectorAll('[data-zone]').forEach((button) => button.addEventListener('click', () => { selectedZone = button.dataset.zone; document.querySelectorAll('[data-zone]').forEach((chip) => chip.setAttribute('aria-pressed', String(chip === button))); document.querySelector('#placement-status').textContent = `${zoneNames[selectedZone]} is selected. Choose its room.`; }));
    document.querySelectorAll('[data-room]').forEach((button) => button.addEventListener('click', () => { placements[selectedZone] = button.dataset.room; render(); document.querySelector('#placement-status').textContent = `${zoneNames[selectedZone]} placed in the ${button.querySelector('strong').textContent}.`; }));
    form?.addEventListener('submit', (event) => { event.preventDefault(); const data = new FormData(form); const input = { species: data.get('species'), homeType: data.get('homeType'), children: data.has('children'), multiplePets: data.has('multiplePets'), highTrafficRooms: data.getAll('traffic'), zones: placements }; const errors = validatePetZoneInput(input); if (errors.length) { errorsBox.innerHTML = `<strong>Finish these placements:</strong><ul>${errors.map((error) => `<li>${error}</li>`).join('')}</ul>`; result.hidden = true; errorsBox.scrollIntoView({ behavior: 'smooth', block: 'center' }); return; } errorsBox.innerHTML = ''; const output = evaluatePetZones(input); document.querySelector('#result-status').textContent = output.label; document.querySelector('#result-summary').textContent = output.classification === 'ready' ? 'The everyday routines are separated and distributed with no major layout conflict.' : output.classification === 'workable' ? 'The plan can work after the priority pressure points below are adjusted.' : 'Move the essential food, water, and hygiene functions apart before arranging the smaller details.'; list('#result-noticed', [...output.critical, ...output.cautions]); list('#result-strengths', output.strengths); list('#result-priorities', output.priorities); list('#result-avoid', output.avoid); result.hidden = false; result.focus(); });
    document.querySelector('#clear-plan')?.addEventListener('click', () => { placements = {}; render(); errorsBox.innerHTML = ''; result.hidden = true; document.querySelector('#placement-status').textContent = 'Feeding is selected. Choose its room.'; });
    document.querySelector('#print-result')?.addEventListener('click', () => window.print());
  </script>
</BaseLayout>
