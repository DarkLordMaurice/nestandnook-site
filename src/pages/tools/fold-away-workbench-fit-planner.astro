---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WinnieNote from '../../components/WinnieNote.astro';
import { SITE } from '../../config';
import { TOOLS } from '../../data/tools';
import '../../styles/tools.css';
import '../../styles/workbench-planner-addon.css';

const tool = TOOLS.find((item) => item.slug === 'fold-away-workbench-fit-planner')!;
const canonical = `${SITE.url}${tool.href}`;
const jsonLd = { '@context': 'https://schema.org', '@graph': [
  { '@type': 'WebApplication', '@id': `${canonical}#tool`, name: tool.title, description: tool.description, url: canonical, applicationCategory: 'UtilitiesApplication', operatingSystem: 'Any', isAccessibleForFree: true, publisher: { '@id': `${SITE.url}/#organization` } },
  { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` }, { '@type': 'ListItem', position: 2, name: 'Tools', item: `${SITE.url}/tools/` }, { '@type': 'ListItem', position: 3, name: tool.title, item: canonical }] },
] };
---
<BaseLayout title={`${tool.title} — ${SITE.brand}`} description={tool.description} showDisclosure={false} jsonLd={jsonLd}>
  <article class="tool-page">
    <div class="article-hero-band"><div class="article-hero-text"><span class="washi washi-teal">{tool.eyebrow}</span><h1>{tool.title}</h1></div></div>
    <p class="lede tool-lede">Compare a fold-away bench against the real wall bay, parked-car boundary, open working depth, operator space, and folded passage before choosing a model.</p>
    <div class="tool-privacy-note" role="note"><strong>Private by default:</strong> this planner runs locally in your browser. Measurements are not saved or transmitted.</div>
    <WinnieNote photo="/winnie/headshot-v4-2.jpg"><p>A folding bench only saves space if the folded version still leaves a route and the open version leaves room for a person. Both outlines belong on the tape test.</p></WinnieNote>

    <div class="garage-planner-grid">
      <section class="tool-panel tool-form-panel" aria-labelledby="garage-input-heading">
        <h2 id="garage-input-heading">Measure the garage bay</h2><div id="tool-errors" class="tool-errors" role="alert" aria-live="assertive"></div>
        <form id="workbench-form" class="tool-form" novalidate>
          <fieldset><legend>1. Garage space</legend><div class="tool-field-grid two">
            <div class="tool-field"><label for="unit">Unit</label><select id="unit" name="unit"><option value="in">Inches</option><option value="cm">Centimeters</option></select></div>
            <div class="tool-field"><label for="wallWidth">Usable wall width</label><input id="wallWidth" name="wallWidth" type="number" min="0" step="0.1" required /></div>
            <div class="tool-field"><label for="parkedDepth">Wall to nearest obstacle with car parked</label><input id="parkedDepth" name="parkedDepth" type="number" min="0" step="0.1" required /><small>Measure to the car, shelving, door swing, or other hard boundary.</small></div>
            <div class="tool-field"><label for="openDepthAvailable">Wall to obstacle with car moved</label><input id="openDepthAvailable" name="openDepthAvailable" type="number" min="0" step="0.1" required /></div>
            <div class="tool-field"><label for="passageTarget">Minimum folded passage to preserve</label><input id="passageTarget" name="passageTarget" type="number" min="0" step="0.1" value="30" required /></div>
          </div></fieldset>
          <fieldset><legend>2. Bench and working position</legend><div class="tool-field-grid two">
            <div class="tool-field"><label for="benchWidth">Bench width</label><input id="benchWidth" name="benchWidth" type="number" min="0" step="0.1" required /></div>
            <div class="tool-field"><label for="openDepth">Bench depth when open</label><input id="openDepth" name="openDepth" type="number" min="0" step="0.1" required /></div>
            <div class="tool-field"><label for="foldedDepth">Bench depth when folded</label><input id="foldedDepth" name="foldedDepth" type="number" min="0" step="0.1" required /></div>
            <div class="tool-field"><label for="operatorClearance">Clear space for the person using it</label><input id="operatorClearance" name="operatorClearance" type="number" min="0" step="0.1" value="30" required /></div>
          </div></fieldset>
          <div class="tool-actions"><button class="tool-button" type="submit">Check this workbench</button><button class="tool-button ghost" type="reset">Clear</button></div>
        </form>
      </section>

      <section class="garage-map-card" aria-labelledby="garage-map-heading">
        <div class="visual-heading"><span class="visual-kicker">Winnie’s top-down garage sketch</span><strong id="garage-map-heading">Add measurements to compare both garage modes</strong></div>
        <div class="garage-map-controls"><button class="tool-button ghost" id="parked-view" type="button" aria-pressed="true">Car parked / bench folded</button><button class="tool-button ghost" id="work-view" type="button" aria-pressed="false">Car moved / bench open</button></div>
        <div id="garage-map" class="garage-map" aria-label="Top-down garage fit preview">
          <span class="garage-wall"></span><div id="map-bench" class="garage-bench">fold-away bench</div><span class="garage-clearance">operator clearance</span><span class="garage-boundary parked">parked-car boundary</span><span class="garage-boundary moved">car-moved boundary</span><span id="map-car" class="garage-car"></span>
        </div>
        <p id="map-caption">The preview scales after the required measurements are entered.</p>
      </section>
    </div>

    <section id="workbench-result" class="tool-panel tool-result workbench-result" aria-labelledby="result-heading" aria-live="polite" tabindex="-1" hidden>
      <span id="result-status" class="tool-result-status">Result</span><h2 id="result-heading">Your workbench-fit result</h2><p id="result-summary"></p>
      <div class="tool-metrics"><div class="tool-metric"><span>Wall-width margin</span><strong id="metric-width">—</strong></div><div class="tool-metric"><span>Folded passage</span><strong id="metric-passage">—</strong></div><div class="tool-metric"><span>Parked work margin</span><strong id="metric-parked">—</strong></div><div class="tool-metric"><span>Car-moved work margin</span><strong id="metric-moved">—</strong></div></div>
      <div class="tool-result-section"><h3>Winnie noticed</h3><ul id="result-reasons"></ul></div><div class="tool-result-section"><h3>Fix first</h3><p id="result-fix"></p></div><div class="tool-result-section"><h3>Measure before buying</h3><ul id="result-measure"></ul></div><div class="tool-result-section"><h3>Avoid</h3><ul id="result-avoid"></ul></div>
      <p class="tool-disclaimer">This tool checks planning dimensions only. It does not assess structure, anchors, load capacity, fire separation, codes, electrical clearances, vehicle safety, accessibility, or manufacturer installation requirements.</p>
      <div class="tool-actions"><button id="print-result" class="tool-button secondary" type="button">Print tape checklist</button><button id="copy-result" class="tool-button ghost" type="button">Copy result</button></div>
    </section>
    <section class="tool-related"><h2>Read next</h2><ul>{tool.relatedGuides.map((guide) => <li><a href={guide.href}>{guide.label}</a></li>)}</ul></section>
  </article>

  <script>
    import { evaluateWorkbench, validateWorkbenchInput } from '../../lib/tools/fold-away-workbench.mjs';
    const form = document.querySelector('#workbench-form'); const result = document.querySelector('#workbench-result'); const errorsBox = document.querySelector('#tool-errors'); const map = document.querySelector('#garage-map'); const bench = document.querySelector('#map-bench'); const car = document.querySelector('#map-car');
    const number = (data, name) => Number(data.get(name)); const inputFromForm = () => { const data = new FormData(form); return { unit: data.get('unit'), wallWidth: number(data, 'wallWidth'), parkedDepth: number(data, 'parkedDepth'), openDepthAvailable: number(data, 'openDepthAvailable'), benchWidth: number(data, 'benchWidth'), openDepth: number(data, 'openDepth'), foldedDepth: number(data, 'foldedDepth'), operatorClearance: number(data, 'operatorClearance'), passageTarget: number(data, 'passageTarget') }; };
    const text = (selector, value) => { const element = document.querySelector(selector); if (element) element.textContent = value; }; const list = (selector, items) => { const element = document.querySelector(selector); if (!element) return; element.innerHTML = ''; items.forEach((item) => { const li = document.createElement('li'); li.textContent = item; element.appendChild(li); }); };
    const draw = () => { const input = inputFromForm(); if (![input.wallWidth,input.parkedDepth,input.openDepthAvailable,input.benchWidth,input.openDepth,input.foldedDepth,input.operatorClearance].every((value) => Number.isFinite(value) && value > 0)) return; const maxDepth = Math.max(input.openDepthAvailable, input.openDepth + input.operatorClearance); map.style.setProperty('--bench-width', `${Math.min(90, Math.max(20, input.benchWidth / input.wallWidth * 88))}%`); map.style.setProperty('--bench-open', `${Math.min(70, input.openDepth / maxDepth * 88)}%`); map.style.setProperty('--bench-folded', `${Math.min(30, input.foldedDepth / maxDepth * 88)}%`); map.style.setProperty('--parked-line', `${Math.min(94, input.parkedDepth / maxDepth * 88)}%`); map.style.setProperty('--moved-line', `${Math.min(96, input.openDepthAvailable / maxDepth * 88)}%`); const working = input.openDepth + input.operatorClearance; map.classList.toggle('garage-warning', working > input.openDepthAvailable || input.benchWidth > input.wallWidth); text('#map-caption', `Open bench + working position: ${Math.round(working * 10) / 10} ${input.unit}. Folded passage: ${Math.round((input.parkedDepth - input.foldedDepth) * 10) / 10} ${input.unit}.`); };
    const setMode = (open) => { bench.classList.toggle('open', open); car.classList.toggle('moved', open); document.querySelector('#parked-view').setAttribute('aria-pressed', String(!open)); document.querySelector('#work-view').setAttribute('aria-pressed', String(open)); };
    document.querySelector('#parked-view')?.addEventListener('click', () => setMode(false)); document.querySelector('#work-view')?.addEventListener('click', () => setMode(true)); form?.addEventListener('input', draw);
    const fixes = { ready: 'Keep the measured layout and perform the full painter’s-tape test before ordering.', tight: 'Choose a narrower or shallower model to turn a technically positive margin into a forgiving one.', 'move-car': 'Treat this as a two-mode garage: store folded with the car parked and work only after the vehicle is moved.', 'no-fit': 'Reduce bench width or depth, relocate the bay, or preserve a smaller project surface rather than sacrificing the passage.', recheck: 'Repeat the tightest measurement from the proudest obstruction and verify the manufacturer’s complete open and folded dimensions.' };
    form?.addEventListener('submit', (event) => { event.preventDefault(); const input = inputFromForm(); const errors = validateWorkbenchInput(input); if (errors.length) { errorsBox.innerHTML = `<strong>Check these measurements:</strong><ul>${errors.map((error) => `<li>${error}</li>`).join('')}</ul>`; result.hidden = true; return; } errorsBox.innerHTML = ''; const output = evaluateWorkbench(input); text('#result-status', output.label); text('#result-summary', `The bench needs ${output.requiredWorkingDepth} ${input.unit} in working mode and leaves ${output.foldedPassage} ${input.unit} of passage when folded.`); text('#metric-width', `${output.widthMargin} ${input.unit}`); text('#metric-passage', `${output.foldedPassage} ${input.unit}`); text('#metric-parked', `${output.parkedWorkMargin} ${input.unit}`); text('#metric-moved', `${output.movedWorkMargin} ${input.unit}`); text('#result-fix', fixes[output.classification]); list('#result-reasons', output.reasons); list('#result-measure', output.measureBeforeBuying); list('#result-avoid', output.avoid); result.hidden = false; result.focus(); });
    form?.addEventListener('reset', () => { errorsBox.innerHTML = ''; result.hidden = true; setMode(false); }); document.querySelector('#print-result')?.addEventListener('click', () => window.print()); document.querySelector('#copy-result')?.addEventListener('click', async () => { const copy = `${document.querySelector('#result-status')?.textContent}\n${document.querySelector('#result-summary')?.textContent}`; try { await navigator.clipboard.writeText(copy); text('#copy-result', 'Copied'); } catch { text('#copy-result', 'Copy unavailable'); } });
  </script>
</BaseLayout>
