---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, isAmazonAssociatesApproved } from '../config.ts';
import { AUTHORS } from '../authors.ts';
import HeroCollage from '../components/HeroCollage.astro';
---
<BaseLayout title={`About — ${SITE.brand}`} description={`Who's behind ${SITE.brand} and how we research and rank the gear we recommend.`} showDisclosure={false}>
  <section class="hero-banner hero-banner-collage">
    <div class="hero-banner-inner">
      <div>
        <span class="washi washi-teal">About the nook</span>
        <h1>About {SITE.brand}</h1>
        <p class="lede">{SITE.brand} helps people build better home office and small-space kitchen setups without overspending. We focus on affordable accessories that solve a specific daily problem, and we rank them by who each option genuinely suits.</p>
      </div>
      <HeroCollage
        seed="about"
        anchor={{ src: '/winnie/portrait-v2.jpg', alt: "Winnie Hollowell, Nest & Nook's virtual host", portrait: true }}
        accents={[
          { src: '/winnie/about-hero.jpg', alt: 'Winnie marking a measurement in pencil on a plank of wood in a practical home-project scene' },
          { src: '/winnie/winnie-life-sorting-drawer.jpg', alt: 'Winnie reorganizing a packed junk drawer' },
        ]}
      />
    </div>
  </section>

  <div class="prose">
    <section id="meet-winnie" class="meet-winnie">
      <div class="polaroid" style="max-width:260px">
        <img src="/winnie/portrait.jpg" alt="Winnie Hollowell, the AI-generated editorial host of Nest & Nook" class="winnie-portrait" width="380" height="380" />
      </div>
      <div>
        <h2>Meet Winnie</h2>
        <p><strong>Winnie Hollowell is a fully virtual, AI-generated spokesperson—not a real person.</strong> She is the face and voice of Nest & Nook: equal parts magpie for anything shiny and well organized, walking citation machine for “but what do the reviews actually say,” and the reason our copy has opinions instead of just specs.</p>
        <p>Winnie does not test products, own the desks or kitchens shown in her images, or provide professional credentials. Our guides are built by comparing public product specifications, recurring patterns in buyer feedback, and the practical measurements that matter for a specific small-space problem. Winnie presents those findings; she is not the person who physically tested them.</p>
        <p>Any page that uses her likeness treats the scene as an illustration, not evidence of personal ownership or use.</p>
      </div>
    </section>

    <section class="affiliate-disclosure">
      <h3 style="margin-top:0">A note on Winnie's photos</h3>
      <p>Some images show Winnie holding, using, or standing near a generic product category in a home office or kitchen setting. Those images are AI-rendered demonstrations. They illustrate a setup problem, measurement, or solution category and do not document a real photoshoot, a personal purchase, or hands-on testing of a branded item.</p>
    </section>

    <h2>What we actually care about</h2>
    <p><strong>Specific over generic.</strong> “Best overall” means little without knowing who it is for. We rank by use case, dimensions, space constraints, and trade-offs.</p>
    <p><strong>Honest about the trade-offs.</strong> Every pick should explain who should skip it, not just who might like it.</p>
    <p><strong>No pay-to-play.</strong> A commission opportunity does not determine which product is ranked first.</p>

    <h2>How we make money</h2>
    {isAmazonAssociatesApproved ? (
      <p>We may earn affiliate commissions when readers buy through qualifying links. We may add display advertising later, but ads are not currently part of the site unless this page is updated to say otherwise. Neither commissions nor future ads change our rankings. See the <a href="/disclosure/">retailer and affiliate disclosure</a> and <a href="/editorial-standards/">editorial standards</a>.</p>
    ) : (
      <p>Our Amazon Associates application is currently pending. Amazon links are untagged and do not currently earn us a commission. We may add affiliate commissions and display advertising later, but only after updating the site’s public disclosures and configuration. See the <a href="/disclosure/">retailer and affiliate disclosure</a>.</p>
    )}

    <h2>Who is accountable for this site</h2>
    {Object.values(AUTHORS).map((a) => (
      <section>
        <h3>{a.name} — <span>{a.role}</span></h3>
        <p>{a.bio}</p>
      </section>
    ))}

    <h2>Contact</h2>
    <p>Questions, correction requests, and privacy inquiries can be sent through our <a href="/contact/">contact page</a>.</p>
  </div>
</BaseLayout>
