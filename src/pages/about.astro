---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config.ts';
import { AUTHORS } from '../authors.ts';
import HeroCollage from '../components/HeroCollage.astro';
---
<BaseLayout title={`About — ${SITE.brand}`} description={`Who's behind ${SITE.brand} and how we review and rank the gear we recommend.`} showDisclosure={false}>
  <div class="prose">
  <span class="washi washi-teal">About the nook</span>
  <h1>About {SITE.brand}</h1>
  <p class="lede">{SITE.brand} helps people build better home office and small-space kitchen setups without overspending. We focus on the affordable accessories that actually change how a space feels day to day — footrests, stands, cable management, desk pads, kitchen space-savers — and we rank them by who each product genuinely suits.</p>

  <section class="hero-banner hero-banner-single hero-banner-collage">
    <div class="hero-banner-inner">
      <HeroCollage
        anchor={{ src: '/winnie/portrait-v2.jpg', alt: "Winnie Hollowell, Nest & Nook's virtual host", tilt: 'right', portrait: true }}
        accents={[
          { src: '/winnie/winnie-life-journaling.jpg', alt: 'Winnie journaling at her cluttered desk', pos: 'bl', tilt: 'left' },
        ]}
        doodle="she collects pins. don't ask."
      />
    </div>
  </section>

  <section id="meet-winnie" class="meet-winnie">
    <div class="polaroid" style="max-width:260px">
      <img src="/winnie/portrait.jpg" alt="Winnie Hollowell" class="winnie-portrait" width="380" height="380" />
    </div>
    <div>
      <h2>Meet Winnie</h2>
      <p><strong>Winnie Hollowell is a fully virtual, AI-generated spokesperson — not a real person.</strong> She's the face and voice of Nest & Nook: equal parts magpie for anything shiny and well-organized, walking citation machine for "but what do the reviews actually say," and the reason our copy has opinions instead of just specs. Think of her as our host, not our reporter. If you've ever reorganized a junk drawer at 1am out of pure spite, you already understand her a little.</p>
      <p>That distinction matters, so we'll say it plainly: Winnie doesn't test products, and she doesn't own the desks or kitchens she talks about. We don't buy and personally test everything we recommend, either — the actual research behind every guide is our real editorial team digging through verified buyer reviews and comparing specs, then ranking picks by fit. Winnie showcases those findings in her own voice — "the reviews say," "here's what buyers keep picking" — she's presenting the results, opinions and all, not claiming to be the one who tested them.</p>
      <p>We're upfront about this because we think you'd rather know than wonder. If a video or post ever features her likeness, it'll say so.</p>
    </div>
  </section>

  <section class="affiliate-disclosure">
    <h3 style="margin-top:0">A note on Winnie's photos</h3>
    <p>Some images show Winnie holding, using, or standing near a product, or in a home office/kitchen setting. Those images are AI-rendered for demonstration purposes — they're illustrating the pick, not documenting a real photoshoot or real personal use. The actual product details, specs, and pricing always come from the real listing, which we link to directly.</p>
  </section>

  <h2>What we actually care about</h2>
  <p>We built Nest & Nook around a small idea: most home office and kitchen problems don't need a full redesign, they need one specific, well-chosen fix. So we optimize for a few things above everything else.</p>
  <p><strong>Specific over generic.</strong> "Best overall" means nothing without knowing who it's for. We rank by who a product genuinely suits — height, space constraints, budget — not by what photographs well.</p>
  <p><strong>Honest about the trade-offs.</strong> Every pick gets real pros and cons, not just a highlight reel. If something's not for you, we'll say so.</p>
  <p><strong>No pay-to-play.</strong> Nothing on this site is ranked higher because a brand paid us. Our affiliate commissions don't change our picks — see how below.</p>

  <h2>How we make money</h2>
  <p>We earn affiliate commissions when you buy through our links, and we run display ads. Neither ever changes our rankings or costs you anything extra. See our <a href="/disclosure/">affiliate disclosure</a> and <a href="/editorial-standards/">editorial standards</a>.</p>

  <h2>Who writes this</h2>
  {Object.values(AUTHORS).map((a) => (
    <section>
      <h3>{a.name} — <span>{a.role}</span></h3>
      <p>{a.bio}</p>
    </section>
  ))}
  </div>
</BaseLayout>
