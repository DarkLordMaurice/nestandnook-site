---
import BaseLayout from '../layouts/BaseLayout.astro';
import WinnieNote from '../components/WinnieNote.astro';
import ReviewCard from '../components/ReviewCard.astro';
import RecipeCard from '../components/RecipeCard.astro';
import BlogCard from '../components/BlogCard.astro';
import ToolCard from '../components/tools/ToolCard.astro';
import { SITE } from '../config.ts';
import { HUBS } from '../hubs.ts';
import { LIVE_TOOLS } from '../data/tools.ts';
import { getCollection } from 'astro:content';
import '../styles/tools.css';
import '../styles/tools-discovery-addon.css';

const reviews = await getCollection('reviews');
const blogPosts = await getCollection('blog');
const recipes = await getCollection('recipes');

// Capped to a teaser (matching latestRecipes/latestPosts below) — previously
// unbounded, so as the Home Office hub grew past a handful of pages the
// homepage was just reprinting the entire hub instead of teasing it. The
// "See all Home Office guides" link is the actual destination for the rest.
const officeReviews = reviews.filter((r) => r.data.hub === 'home-office')
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)
  .slice(0, 4);
const kitchenReviews = reviews.filter((r) => r.data.hub === 'kitchen')
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)
  .slice(0, 4);
const petCareReviews = reviews.filter((r) => r.data.hub === 'pet-care')
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)
  .slice(0, 4);
const garageReviews = reviews.filter((r) => r.data.hub === 'garage')
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)
  .slice(0, 4);
const latestRecipes = [...recipes].sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 4);
// Off the Clock on the homepage should tease the same life-only content as
// /blog/ itself — "Desk fixes"/"Kitchen fixes" posts surface via the
// /guides/ section instead (see src/pages/guides/index.astro and
// src/pages/blog/index.astro for the full split rationale, 2026-07-10).
const LIFE_CATEGORIES = ['Life outside the nook', 'Behind the nook'];
const latestPosts = blogPosts.filter((p) => LIFE_CATEGORIES.includes(p.data.category))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 4);
const TIP_CATEGORIES = ['Desk fixes', 'Kitchen fixes'];
const latestGuides = blogPosts.filter((p) => TIP_CATEGORIES.includes(p.data.category))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 4);
// Homepage shows "Know yourself first" tools only, no Technical tools
// (Maurice, 2026-07-17) — same category-based split already used in
// src/pages/tools/index.astro ('Lifestyle' = personality/gut-check tools,
// everything else = the 4 measurement/Technical tools), reused here rather
// than redefined so the two pages can't drift out of sync on which tools
// count as which.
const personalityTools = LIVE_TOOLS.filter((tool) => tool.category === 'Lifestyle');
---
<BaseLayout
  title={`Small-Space Home Guides & Planning Tools | ${SITE.brand}`}
  description="Practical small-space guides, product research, recipes, and free visual planning tools for home offices, kitchens, apartment pets, and garages."
  showDisclosure={false}
>
  <section class="hero-banner">
    <div class="hero-banner-inner two-col">
      <div>
        <span class="washi">Welcome to the nook</span>
        <h1 class="brand-wordmark-hero">{SITE.brand}</h1>
        <p class="lede">I measure things nobody asked me to measure — desks, counters, pet corners, garage walls, even soup — so you don't have to guess whether it'll fit. Real research, free planning tools, honest recipes, and whatever's rattling around in my head once I'm Off the Clock.</p>
      </div>
      <div class="polaroid">
        <img src="/winnie/hero-full.jpg" alt="Winnie Hollowell, Nest & Nook's virtual host, laughing over coffee at her home-office desk" class="hero-photo" width="800" height="500" />
      </div>
    </div>
  </section>

  <WinnieNote>
    <p>Hi, I'm Winnie — resident magpie for anything that makes a small space less annoying, from desk geometry to pet-zone traffic and garage clearances. The recommendations here synthesize specifications, published evidence, and patterns across buyer feedback; they do not pretend a virtual host personally tested the products. Nothing earns a place because a brand slipped the site a check.</p>
  </WinnieNote>

  {personalityTools.length > 0 && (
    <section class="card-section homepage-tools" aria-labelledby="homepage-tools-title">
      <div class="card-section-head">
        <div>
          <span class="washi">Solve it before you shop</span>
          <h2 id="homepage-tools-title">Free visual planning tools</h2>
        </div>
        <a class="card-section-link" href="/tools/">See all tools →</a>
      </div>
      <p class="homepage-tools-intro">Quizzes and gut-checks for the parts a tape measure can't answer. The measurement-and-fit tools live on the full tools page.</p>
      <div class="tools-grid homepage-tools-grid">
        {personalityTools.slice(0, 4).map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  )}

  {officeReviews.length > 0 && (
    <section class="card-section" id="home-office">
      <div class="card-section-head">
        <h2>Home Office</h2>
        <a class="card-section-link" href="/home-office/">See all Home Office guides →</a>
      </div>
      <div class="masonry">
        {officeReviews.map((r, i) => (
          <ReviewCard
            href={`/${r.data.hub}/${r.slug}/`}
            image={r.data.image ?? HUBS[r.data.hub]?.hero}
            imagePosition={r.data.imagePosition}
            title={r.data.title}
            description={r.data.description}
            pageType={r.data.pageType}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {kitchenReviews.length > 0 && (
    <section class="card-section" id="kitchen">
      <div class="card-section-head">
        <h2>Kitchen</h2>
        <a class="card-section-link" href="/kitchen/">See all Kitchen guides →</a>
      </div>
      <div class="masonry">
        {kitchenReviews.map((r, i) => (
          <ReviewCard
            href={`/${r.data.hub}/${r.slug}/`}
            image={r.data.image ?? HUBS[r.data.hub]?.hero}
            imagePosition={r.data.imagePosition}
            title={r.data.title}
            description={r.data.description}
            pageType={r.data.pageType}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {petCareReviews.length > 0 && (
    <section class="card-section" id="pet-care">
      <div class="card-section-head">
        <h2>Pet Care</h2>
        <a class="card-section-link" href="/pet-care/">See all Pet Care guides →</a>
      </div>
      <div class="masonry">
        {petCareReviews.map((r, i) => (
          <ReviewCard
            href={`/${r.data.hub}/${r.slug}/`}
            image={r.data.image ?? HUBS[r.data.hub]?.hero}
            imagePosition={r.data.imagePosition}
            title={r.data.title}
            description={r.data.description}
            pageType={r.data.pageType}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {garageReviews.length > 0 && (
    <section class="card-section" id="garage">
      <div class="card-section-head">
        <h2>Garage</h2>
        <a class="card-section-link" href="/garage/">See all Garage guides →</a>
      </div>
      <div class="masonry">
        {garageReviews.map((r, i) => (
          <ReviewCard
            href={`/${r.data.hub}/${r.slug}/`}
            image={r.data.image ?? HUBS[r.data.hub]?.hero}
            imagePosition={r.data.imagePosition}
            title={r.data.title}
            description={r.data.description}
            pageType={r.data.pageType}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {latestRecipes.length > 0 && (
    <section class="card-section" id="recipes">
      <div class="card-section-head">
        <h2>Recipes</h2>
        <a class="card-section-link" href="/recipes/">See all recipes →</a>
      </div>
      <div class="masonry">
        {latestRecipes.map((r, i) => (
          <RecipeCard
            href={`/recipes/${r.slug}/`}
            image={r.data.image}
            title={r.data.title}
            description={r.data.description}
            totalMinutes={r.data.prepTimeMinutes + r.data.cookTimeMinutes}
            servings={r.data.servings}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {latestGuides.length > 0 && (
    <section class="card-section" id="guides">
      <div class="card-section-head">
        <h2>Guides</h2>
        <a class="card-section-link" href="/guides/">See all guides →</a>
      </div>
      <div class="masonry">
        {latestGuides.map((p, i) => (
          <BlogCard
            href={`/blog/${p.slug}/`}
            image={p.data.image}
            imagePosition={p.data.imagePosition}
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {latestPosts.length > 0 && (
    <section class="card-section" id="off-the-clock">
      <div class="card-section-head">
        <h2>Off the Clock</h2>
        <a class="card-section-link" href="/blog/">See more →</a>
      </div>
      <div class="masonry">
        {latestPosts.map((p, i) => (
          <BlogCard
            href={`/blog/${p.slug}/`}
            image={p.data.image}
            imagePosition={p.data.imagePosition}
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .homepage-tools {
    margin-top: 2.5rem;
    padding: clamp(1.1rem, 3vw, 2rem);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 4px);
    background:
      radial-gradient(circle at 92% 8%, rgba(184, 129, 54, .2), transparent 24%),
      linear-gradient(135deg, #fffaf0, #f2e5cc);
    box-shadow: var(--shadow-card);
  }
  .homepage-tools .card-section-head { align-items: end; }
  .homepage-tools .card-section-head h2 { margin: .45rem 0 0; }
  .homepage-tools-intro { max-width: 72ch; margin: .6rem 0 1.35rem; }
  .homepage-tools-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .homepage-tools-grid .tool-card { background: rgba(255, 253, 246, .94); }
  @media (max-width: 760px) {
    .homepage-tools-grid { grid-template-columns: 1fr; }
    .homepage-tools .card-section-head { align-items: start; }
  }
</style>
