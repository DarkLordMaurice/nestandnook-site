---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config.ts';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');
reviews.sort((a, b) => +b.data.publishDate - +a.data.publishDate);
---
<BaseLayout
  title={`${SITE.brand} — ${SITE.tagline}`}
  description="Hands-on rankings and buying guides for home office ergonomics and small-space kitchen gear. Independent picks, honest trade-offs."
  showDisclosure={false}
>
  <h1>{SITE.brand}</h1>
  <p>{SITE.tagline} We test and rank gear so you buy once and buy right — starting with home office ergonomics and small-space kitchen tools.</p>

  <h2>Latest guides</h2>
  {reviews.length === 0 ? (
    <p><em>First guides publishing soon.</em></p>
  ) : (
    <ul>
      {reviews.map((r) => (
        <li>
          <a href={`/${r.data.hub}/${r.slug}/`}>{r.data.title}</a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
