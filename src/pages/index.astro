---
import BaseLayout from '../layouts/BaseLayout.astro';
import WinnieNote from '../components/WinnieNote.astro';
import { SITE } from '../config.ts';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');
reviews.sort((a, b) => +b.data.publishDate - +a.data.publishDate);
---
<BaseLayout
  title={`${SITE.brand} — ${SITE.tagline}`}
  description="Review-backed rankings and buying guides for home office ergonomics and small-space kitchen gear. Independent picks, honest trade-offs."
  showDisclosure={false}
>
  <section class="hero-banner">
    <div class="hero-banner-inner two-col">
      <div>
        <span class="washi">Welcome to the nook</span>
        <h1>{SITE.brand}</h1>
        <p class="lede">I've read more desk and kitchen reviews than any reasonable person should admit to, and I've turned all of it into one shortlist: gear that actually earns its spot in a small space — starting with home office ergonomics and small-space kitchen tools.</p>
        <a class="hero-cta" href="/home-office/">Start with Home Office →</a>
        <span class="doodle hero-doodle">psst, start here!</span>
      </div>
      <div class="polaroid">
        <img src="/winnie/hero-full.jpg" alt="Winnie Hollowell, Nest & Nook's virtual host, in her home office" class="hero-photo" width="800" height="500" />
      </div>
    </div>
  </section>

  <WinnieNote>
    <p>Hi, I'm Winnie — resident magpie for anything that makes a desk or a kitchen less annoying, and I have zero chill about a good spec sheet. I don't test anything myself (see the fine print, it matters), but I read reviews with the focus most people save for true crime, and this whole site is basically my "here's what buyers actually keep" list. Every pick below earned its spot — nothing's here because a brand slipped us a check.</p>
  </WinnieNote>

  <h2>Latest guides</h2>
  {reviews.length === 0 ? (
    <p><em>First guides publishing soon.</em></p>
  ) : (
    <ul class="guide-grid">
      {reviews.map((r) => (
        <li class="guide-card">
          <a class="title-link" href={`/${r.data.hub}/${r.slug}/`}>{r.data.title}</a>
          <p>{r.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
