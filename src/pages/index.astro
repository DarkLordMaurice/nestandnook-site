---
import BaseLayout from '../layouts/BaseLayout.astro';
import WinnieNote from '../components/WinnieNote.astro';
import ReviewCard from '../components/ReviewCard.astro';
import RecipeCard from '../components/RecipeCard.astro';
import BlogCard from '../components/BlogCard.astro';
import SideRail from '../components/SideRail.astro';
import { SITE } from '../config.ts';
import { HUBS } from '../hubs.ts';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');
const blogPosts = await getCollection('blog');
const recipes = await getCollection('recipes');

const officeReviews = reviews.filter((r) => r.data.hub === 'home-office')
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const kitchenReviews = reviews.filter((r) => r.data.hub === 'kitchen')
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const latestRecipes = [...recipes].sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 6);
const latestPosts = [...blogPosts].sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 6);
---
<BaseLayout
  title={`${SITE.brand} — ${SITE.tagline}`}
  description="Review-backed rankings and buying guides for home office ergonomics and small-space kitchen gear. Independent picks, honest trade-offs."
  showDisclosure={false}
>
  <SideRail
    heading="Jump to"
    links={[
      { label: 'Home Office', href: '#home-office' },
      { label: 'Kitchen', href: '#kitchen' },
      { label: 'Recipes', href: '#recipes' },
      { label: "Winnie's Notes", href: '#winnies-notes' },
    ]}
  />
  <section class="hero-banner">
    <div class="hero-banner-inner two-col">
      <div>
        <span class="washi">Welcome to the nook</span>
        <h1>{SITE.brand}</h1>
        <p class="lede">I've read more desk and kitchen reviews than any reasonable person should admit to, and I've turned all of it into one shortlist: gear that actually earns its spot in a small space — starting with home office ergonomics and small-space kitchen tools.</p>
        <a class="hero-cta" href="/home-office/">Start with Home Office →</a>
        <span class="doodle hero-doodle">psst, start here!</span>
      </div>
      <div class="polaroid">
        <img src="/winnie/hero-full.jpg" alt="Winnie Hollowell, Nest & Nook's virtual host, in her home office" class="hero-photo" width="800" height="500" />
      </div>
    </div>
  </section>

  <WinnieNote>
    <p>Hi, I'm Winnie — resident magpie for anything that makes a desk or a kitchen less annoying, and I have zero chill about a good spec sheet. I don't test anything myself (see the fine print, it matters), but I read reviews with the focus most people save for true crime, and this whole site is basically my "here's what buyers actually keep" list. Every pick below earned its spot — nothing's here because a brand slipped us a check.</p>
  </WinnieNote>

  {officeReviews.length > 0 && (
    <section class="card-section" id="home-office">
      <div class="card-section-head">
        <h2>Home Office</h2>
        <a class="card-section-link" href="/home-office/">See all Home Office guides →</a>
      </div>
      <div class="masonry">
        {officeReviews.map((r, i) => (
          <ReviewCard
            href={`/${r.data.hub}/${r.slug}/`}
            image={r.data.image ?? HUBS[r.data.hub]?.hero}
            title={r.data.title}
            description={r.data.description}
            pageType={r.data.pageType}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {kitchenReviews.length > 0 && (
    <section class="card-section" id="kitchen">
      <div class="card-section-head">
        <h2>Kitchen</h2>
        <a class="card-section-link" href="/kitchen/">See all Kitchen guides →</a>
      </div>
      <div class="masonry">
        {kitchenReviews.map((r, i) => (
          <ReviewCard
            href={`/${r.data.hub}/${r.slug}/`}
            image={r.data.image ?? HUBS[r.data.hub]?.hero}
            title={r.data.title}
            description={r.data.description}
            pageType={r.data.pageType}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {latestRecipes.length > 0 && (
    <section class="card-section" id="recipes">
      <div class="card-section-head">
        <h2>Recipes</h2>
        <a class="card-section-link" href="/recipes/">See all recipes →</a>
      </div>
      <div class="masonry">
        {latestRecipes.map((r, i) => (
          <RecipeCard
            href={`/recipes/${r.slug}/`}
            image={r.data.image}
            title={r.data.title}
            description={r.data.description}
            totalMinutes={r.data.prepTimeMinutes + r.data.cookTimeMinutes}
            servings={r.data.servings}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}

  {latestPosts.length > 0 && (
    <section class="card-section" id="winnies-notes">
      <div class="card-section-head">
        <h2>Winnie's Notes</h2>
        <a class="card-section-link" href="/blog/">See all notes →</a>
      </div>
      <div class="masonry">
        {latestPosts.map((p, i) => (
          <BlogCard
            href={`/blog/${p.slug}/`}
            image={p.data.image}
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            featured={i === 0}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
