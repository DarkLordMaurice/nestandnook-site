---
import BaseLayout from '../layouts/BaseLayout.astro';
import WinnieNote from '../components/WinnieNote.astro';
import { SITE } from '../config.ts';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');
reviews.sort((a, b) => +b.data.publishDate - +a.data.publishDate);
---
<BaseLayout
  title={`${SITE.brand} — ${SITE.tagline}`}
  description="Hands-on rankings and buying guides for home office ergonomics and small-space kitchen gear. Independent picks, honest trade-offs."
  showDisclosure={false}
>
  <section class="hero">
    <span class="washi">Welcome to the nook</span>
    <h1>{SITE.brand}</h1>
    <p class="lede">{SITE.tagline} We test and rank gear so you buy once and buy right — starting with home office ergonomics and small-space kitchen tools.</p>
  </section>

  <WinnieNote>
    <p>Hi, I'm Winnie. I've reorganized more desks and cabinets than I can count, and this whole site is basically my "if I had to do it again, here's exactly what I'd buy" list. Every pick below earned its spot — nothing's here because a brand paid for it.</p>
  </WinnieNote>

  <h2>Latest guides</h2>
  {reviews.length === 0 ? (
    <p><em>First guides publishing soon.</em></p>
  ) : (
    <ul class="guide-grid">
      {reviews.map((r) => (
        <li class="guide-card">
          <a class="title-link" href={`/${r.data.hub}/${r.slug}/`}>{r.data.title}</a>
          <p>{r.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
