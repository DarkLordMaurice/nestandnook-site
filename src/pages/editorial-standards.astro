---
import BaseLayout from '../layouts/BaseLayout.astro';
import WinnieNote from '../components/WinnieNote.astro';
import { SITE, isAmazonAssociatesApproved } from '../config.ts';
---
<BaseLayout title={`Editorial Standards — ${SITE.brand}`} description={`How ${SITE.brand} researches, reviews, updates, and corrects product guidance.`} showDisclosure={false}>
  <div class="prose">
    <span class="washi">The fine print, warmly</span>
    <h1>Editorial Standards</h1>
    <p class="lede">These standards apply to every guide on {SITE.brand}. They exist so readers can understand what our recommendations do—and do not—claim.</p>

    <WinnieNote>
      <p>Boring-but-important stuff ahead. Here is how something earns a spot, what gets checked, and what should block publication.</p>
    </WinnieNote>

    <h2>How we research and rank products</h2>
    <ul>
      <li>We do not claim hands-on testing unless a page explicitly documents real testing.</li>
      <li>We compare public product specifications and recurring patterns in buyer feedback.</li>
      <li>Picks are organized by fit for a specific person, measurement, room, or use case—not by commission rate.</li>
      <li>We explain what to measure, what to look for, and who should skip an option.</li>
      <li>Generated Winnie images are illustrative demonstrations using generic product categories, not evidence of branded testing.</li>
    </ul>

    <h2>Accuracy and claim boundaries</h2>
    <ul>
      <li>We do not invent ratings, review counts, testimonials, credentials, prices, availability, or ASINs.</li>
      <li>Changing prices are not stated as permanent facts; readers are sent to the current retailer listing.</li>
      <li>Market-wide claims are narrowed to the products or evidence actually compared.</li>
      <li>Comfort and setup guidance is not medical diagnosis or treatment.</li>
      <li>Certification claims are attributed to model-specific manufacturer or certifier documentation and should be rechecked during refreshes.</li>
    </ul>

    <h2>Updates and corrections</h2>
    <ul>
      <li>Pages display a published date and a visible last-reviewed date.</li>
      <li>Product links, specifications, internal links, and claim wording are reviewed on a scheduled and event-triggered basis.</li>
      <li>Correction requests can be sent through the <a href="/contact/">contact page</a>.</li>
    </ul>

    <h2>Monetization</h2>
    {isAmazonAssociatesApproved ? (
      <p>{SITE.brand} may earn qualifying affiliate commissions. Display ads are only described as active when they are actually active. Monetization does not change recommendation criteria. See the <a href="/disclosure/">full disclosure</a>.</p>
    ) : (
      <p>The Amazon Associates application is pending. Current Amazon links are untagged and do not earn a commission. Display ads are not currently represented as active. See the <a href="/disclosure/">full disclosure</a>.</p>
    )}
  </div>
</BaseLayout>
