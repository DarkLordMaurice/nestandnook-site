---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import HeroCollage from '../../components/HeroCollage.astro';
import { SITE } from '../../config.ts';
import { getCollection } from 'astro:content';

const recipes = await getCollection('recipes');
recipes.sort((a, b) => +b.data.publishDate - +a.data.publishDate);
---
<BaseLayout
  title={`Recipes — ${SITE.brand}`}
  description="Simple, well-tested recipes for small kitchens — the ones people search for most, plus the gear that makes each one easier."
  showDisclosure={false}
>
  <section class="hero-banner hero-banner-collage">
    <div class="hero-banner-inner">
      <div>
        <span class="washi">From the Nest &amp; Nook kitchen</span>
        <h1>Recipes</h1>
        <p class="lede">The dishes people actually search for, written for real kitchens — small counters, one pan, no fuss. Every recipe links to the gear that makes it easier, if you want it.</p>
      </div>
      <HeroCollage
        anchor={{ src: '/winnie/winnie-kitchen-card.jpg', alt: 'Winnie holding a handwritten recipe card in her kitchen', tilt: 'left' }}
        accents={[
          { src: '/winnie/winnie-holding-chocolate-chip-cookies.jpg', alt: 'Winnie holding a tray of chocolate chip cookies', tilt: 'right' },
          { src: '/winnie/winnie-holding-banana-bread.jpg', alt: 'Winnie holding a fresh loaf of banana bread', tilt: 'left' },
        ]}
      />
    </div>
  </section>

  {recipes.length === 0 ? (
    <p><em>First recipes publishing soon.</em></p>
  ) : (
    <div class="masonry">
      {recipes.map((r, i) => (
        <RecipeCard
          href={`/recipes/${r.slug}/`}
          image={r.data.image}
          title={r.data.title}
          description={r.data.description}
          totalMinutes={r.data.prepTimeMinutes + r.data.cookTimeMinutes}
          servings={r.data.servings}
          featured={i === 0}
        />
      ))}
    </div>
  )}
</BaseLayout>
