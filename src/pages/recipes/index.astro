---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config.ts';
import { getCollection } from 'astro:content';

const recipes = await getCollection('recipes');
recipes.sort((a, b) => +b.data.publishDate - +a.data.publishDate);

const categories = ['breakfast', 'main', 'side', 'dessert', 'snack'] as const;
---
<BaseLayout
  title={`Recipes — ${SITE.brand}`}
  description="Simple, well-tested recipes for small kitchens — the ones people search for most, plus the gear that makes each one easier."
  showDisclosure={false}
>
  <section class="hero">
    <span class="washi">From the Nest &amp; Nook kitchen</span>
    <h1>Recipes</h1>
    <p class="lede">The dishes people actually search for, written for real kitchens — small counters, one pan, no fuss. Every recipe links to the gear that makes it easier, if you want it.</p>
  </section>

  {recipes.length === 0 ? (
    <p><em>First recipes publishing soon.</em></p>
  ) : (
    <ul class="guide-grid post-grid">
      {recipes.map((r) => (
        <li class="guide-card post-card">
          <a href={`/recipes/${r.slug}/`} class="post-card-image-link">
            <img src={r.data.image} alt="" class="post-card-image" width="500" height="300" />
          </a>
          <span class="eyebrow">{r.data.category}</span>
          <a class="title-link" href={`/recipes/${r.slug}/`}>{r.data.title}</a>
          <p>{r.data.description}</p>
          <p class="recipe-index-meta">{r.data.prepTimeMinutes + r.data.cookTimeMinutes} min total · Serves {r.data.servings}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
