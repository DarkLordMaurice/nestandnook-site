---
import { SITE } from '../config.ts';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  showDisclosure?: boolean;   // true on all content pages
  jsonLd?: object;            // ItemList/Product/Article schema from the page
  author?: string;            // byline name for content pages (E-E-A-T)
  publishDate?: Date;         // visible freshness signal alongside the byline
  updatedDate?: Date;
}
const { title, description, ogImage, showDisclosure = true, jsonLd, author, publishDate, updatedDate } = Astro.props;
const dateFmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const canonical = new URL(Astro.url.pathname, SITE.url).toString();

// Sitewide entity graph — Organization + WebSite + a real named Person
// (Maurice, publisher/editor of record), linked via @id so every page's
// specific schema (ItemList/Article/Recipe/FAQPage from `jsonLd`) hangs off
// the same graph instead of shipping as a disconnected second <script> tag.
//
// Deliberately NOT modeling Winnie as schema.org Person: she's disclosed
// sitewide (see about.astro) as a fully virtual, AI-generated host, not a
// real individual. schema.org Person is meant to represent real, identifiable
// people — marking an AI persona as one would be exactly the kind of
// misleading structured data Google's guidelines warn against, and it cuts
// against this site's own honesty commitments. Maurice is real and named, so
// he's the Person entity; Winnie stays a voice/character, not a schema node.
const orgId = `${SITE.url}/#organization`;
const websiteId = `${SITE.url}/#website`;
const publisherId = `${SITE.url}/#maurice`;

const orgSchema = {
  '@type': 'Organization',
  '@id': orgId,
  name: SITE.brand,
  url: SITE.url,
  description: SITE.tagline,
  founder: { '@id': publisherId },
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': websiteId,
  url: SITE.url,
  name: SITE.brand,
  publisher: { '@id': orgId },
};

const publisherSchema = {
  '@type': 'Person',
  '@id': publisherId,
  name: 'Maurice',
  jobTitle: 'Founder & Publisher',
  url: `${SITE.url}/about/`,
};

// Flatten whatever the page passed in `jsonLd` (a single node, or its own
// {'@context', '@graph': [...]} shape like the recipe pages build) into this
// page's graph, stripping any nested '@context' so there's exactly one.
const pageNodes: object[] = jsonLd
  ? (Array.isArray((jsonLd as any)['@graph'])
      ? (jsonLd as any)['@graph']
      : [jsonLd]
    ).map((n: any) => {
      const { '@context': _drop, ...rest } = n;
      return rest;
    })
  : [];

const fullGraph = {
  '@context': 'https://schema.org',
  '@graph': [orgSchema, websiteSchema, publisherSchema, ...pageNodes],
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  {author && <meta name="author" content={author} />}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonical} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=Caveat:wght@500;700&family=Cinzel+Decorative:wght@700;900&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(fullGraph)} />
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <a href="/" class="brand"><img src="/favicon.svg?v=2" alt="" class="brand-mark" width="34" height="34" /><span class="brand-word">{SITE.brand}</span></a>
      <div class="site-header-right">
        <nav class="site-nav">
          <a href="/home-office/">Home Office</a>
          <a href="/kitchen/">Kitchen</a>
          <a href="/recipes/">Recipes</a>
          <a href="/guides/">Guides</a>
          <a href="/blog/">Winnie's Notes</a>
          <a href="/about/">About</a>
        </nav>
        <div class="site-search" id="site-search">
          <button type="button" class="site-search-toggle" id="site-search-toggle" aria-label="Search the site" aria-expanded="false">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </button>
          <div class="site-search-panel" id="site-search-panel" hidden>
            <input type="text" id="site-search-input" class="site-search-input" placeholder={`Search ${SITE.brand}…`} autocomplete="off" aria-label="Search the site" />
            <div class="site-search-results" id="site-search-results"></div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <main data-pagefind-body>
    <div class="wrap">
      {showDisclosure && <AffiliateDisclosure />}
      {author && (
        <p class="byline">
          By <a href="/about/">{author}</a>
          {publishDate && <span class="byline-date"> · Published {dateFmt(publishDate)}{updatedDate && updatedDate.getTime() !== publishDate.getTime() && <> · Updated {dateFmt(updatedDate)}</>}</span>}
        </p>
      )}
      <slot />
    </div>
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>{SITE.brand} — {SITE.tagline}</p>
      <p class="small">As an Amazon Associate we earn from qualifying purchases. Prices and availability are accurate as of the date/time indicated and are subject to change.</p>
      <p class="small"><a href="/about/">About</a> · <a href="/editorial-standards/">Editorial Standards</a> · <a href="/disclosure/">Affiliate Disclosure</a> · <a href="/privacy/">Privacy</a></p>
    </div>
  </footer>

  <script>
    // Inline header search — Pagefind core JS API, not the full-page
    // pagefind-ui.js widget. Present on every page via BaseLayout (Maurice,
    // 2026-07-10: search needs to be "a bar at the top, in the main header
    // ... not a separate page all together"). /pagefind/pagefind.js only
    // exists in a built `dist/` (generated by `astro build && pagefind
    // --site dist ...`), so this is silently a no-op in local dev unless a
    // build has been run first — expected, not a bug.
    const wrap = document.getElementById('site-search');
    const toggle = document.getElementById('site-search-toggle');
    const panel = document.getElementById('site-search-panel');
    const input = document.getElementById('site-search-input') as HTMLInputElement | null;
    const results = document.getElementById('site-search-results');

    let pagefind: any;
    let debounceTimer: ReturnType<typeof setTimeout>;

    async function ensurePagefind() {
      if (!pagefind) {
        // @ts-ignore — built at deploy time, path only resolves in dist/
        pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
        await pagefind.init();
      }
      return pagefind;
    }

    function openPanel() {
      if (!panel || !toggle || !input) return;
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      input.focus();
    }
    function closePanel() {
      if (!panel || !toggle || !input || !results) return;
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      results.innerHTML = '';
      input.value = '';
    }

    toggle?.addEventListener('click', () => {
      if (!panel) return;
      if (panel.hidden) openPanel(); else closePanel();
    });

    document.addEventListener('click', (e) => {
      if (wrap && !wrap.contains(e.target as Node)) closePanel();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closePanel();
    });

    input?.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const query = input.value.trim();
      if (!results) return;
      if (!query) {
        results.innerHTML = '';
        return;
      }
      results.innerHTML = '<p class="site-search-loading">Searching…</p>';
      debounceTimer = setTimeout(async () => {
        try {
          const pf = await ensurePagefind();
          const search = await pf.search(query);
          const top = search.results.slice(0, 6);
          if (top.length === 0) {
            results.innerHTML = '<p class="site-search-empty">No results. Try a different word.</p>';
            return;
          }
          const items = await Promise.all(top.map((r: any) => r.data()));
          results.innerHTML = items
            .map(
              (item: any) => `
              <a class="site-search-result" href="${item.url}">
                <span class="site-search-result-title">${item.meta?.title ?? item.url}</span>
                <span class="site-search-result-excerpt">${item.excerpt}</span>
              </a>`
            )
            .join('');
        } catch (err) {
          results.innerHTML = '<p class="site-search-empty">Search isn\'t available right now.</p>';
        }
      }, 180);
    });
  </script>
</body>
</html>
