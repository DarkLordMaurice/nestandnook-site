---
// Placeholder shown in a Winnie photo slot when a page has been published
// ahead of her real photo (image: "PENDING" in frontmatter). Tracked in
// Winnie-Photo-Queue.md until Maurice drops the real photo in, at which
// point the frontmatter switches from "PENDING" to the real file path and
// this component stops rendering for that page. Not an image file, so it
// can never trip check_duplicate_images.py / content-qa's reused-image gate.
//
// Uses the exact same "inline-photo hero-photo" figure classes as a real
// hero photo (see .prose figure.inline-photo.hero-photo in global.css,
// max-width: 420px) so it renders at the identical size — the first version
// of this component used the small collage `.polaroid` classes instead and
// rendered enormous/unstyled. Fixed 2026-07-11.
interface Props {
  tape?: 'teal' | 'hotpink' | 'sage' | 'mustard' | 'gold';
}
const { tape = 'mustard' } = Astro.props;
// Jokes are about Winnie herself — her personality, not a third party like
// "her photographer." Maurice, 2026-07-11: "i want the message to say
// something funny and clever about her, not her photographer."
const jokes = [
  "Winnie is currently negotiating with the camera about her best angle.",
  "Winnie says this outfit isn't final. It will never be final.",
  "Winnie is off measuring something that did not need measuring.",
  "Winnie is mid-opinion about a throw pillow. Photo to follow.",
  "Winnie insists she photographs better on her own schedule.",
  "Somewhere, Winnie is rearranging a shelf that was already fine.",
];
const joke = jokes[Math.floor(Math.random() * jokes.length)];
---
<figure class={`inline-photo hero-photo pending-photo tape-${tape}`}>
  <div class="pending-inner">
    <span class="pending-icon" aria-hidden="true">📸</span>
    <p class="pending-text">{joke}</p>
  </div>
</figure>
<!-- Styling for .pending-photo/.pending-inner/.pending-icon/.pending-text
     lives in global.css (moved 2026-07-11) so the same classes also work on
     raw HTML pasted directly into a markdown body (a second/third Winnie
     placeholder per the 2-Winnie/3-non-Winnie page standard) — Astro's
     scoped <style> only applied to markup this component itself renders. -->
