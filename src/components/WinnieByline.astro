---
// Byline for every blog post. As of 2026-07-03 this no longer repeats the
// AI/virtual-host disclosure inline — that lives once, clearly, on the About
// page (#meet-winnie). Repeating it on every post undercut the read and
// duplicated the same paragraph across dozens of pages; Maurice called this
// out as an immersion problem, same fix already applied to WinnieRecipeByline.
// Winnie is still, in fact, a disclosed virtual/AI host — see Brand-Guide.md
// §2 — this component just doesn't re-explain that every time anymore.
//
// `photo` lets callers vary which headshot shows up so the same face isn't
// repeated on every single post — see brand-assets/winnie/headshots/ for the
// full pool (headshot-v4-1.jpg through -4.jpg, plus the original avatar.jpg).
interface Props {
  photo?: string;
}
const { photo = '/winnie/avatar.jpg' } = Astro.props;
---
<div class="winnie-byline">
  <img src={photo} alt="Winnie Hollowell" width="76" height="76" />
  <div>
    <p class="name">Winnie Hollowell <span class="role">— Nest &amp; Nook's virtual host</span></p>
  </div>
</div>

<style>
  .winnie-byline {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin: 0 0 1.75rem;
  }
  .winnie-byline img {
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 2px var(--gold);
    flex: none;
  }
  .winnie-byline .name {
    margin: 0 0 0.2rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
  }
  .winnie-byline .role {
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--ink-soft);
    font-size: 0.85rem;
  }
</style>
