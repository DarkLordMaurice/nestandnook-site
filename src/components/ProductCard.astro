---
import { amazonLink } from '../config.ts';
interface Props {
  name: string;
  asin: string;
  bestFor: string;
  blurb: string;
  pros?: string[];
  cons?: string[];
}
const { name, asin, bestFor, blurb, pros = [], cons = [] } = Astro.props;
const link = amazonLink(asin);
---
<article class="product-card">
  <div class="badge">{bestFor}</div>
  <h3>{name}</h3>
  <p>{blurb}</p>
  {pros.length > 0 && (
    <ul class="pros">{pros.map((p) => <li>{p}</li>)}</ul>
  )}
  {cons.length > 0 && (
    <ul class="cons">{cons.map((c) => <li>{c}</li>)}</ul>
  )}
  <!-- Honest, uncloaked Amazon link. No price stated as fact. -->
  <a class="cta" href={link} rel="nofollow sponsored" target="_blank">Check price on Amazon →</a>
</article>

<!-- Styling lives in src/styles/global.css (.product-card, .badge, .pros, .cons, .cta)
     so every card on the site — roundups, product-page deep dives — looks consistent. -->
