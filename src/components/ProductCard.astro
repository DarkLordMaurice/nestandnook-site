---
import { amazonLink } from '../config.ts';
interface Props {
  name: string;
  asin: string;
  bestFor: string;
  blurb: string;
  pros?: string[];
  cons?: string[];
  image?: string;         // real product photo — not populated until PA-API unlocks
  winnieImage?: string;   // AI-rendered "Winnie with this product" lifestyle shot — used sporadically
}
const { name, asin, bestFor, blurb, pros = [], cons = [], image, winnieImage } = Astro.props;
const link = amazonLink(asin);
const photo = image ?? winnieImage; // prefer the real product photo once available
---
<article class="product-card">
  {photo && (
    <div class="product-card-photo">
      <img src={photo} alt={name} width="400" height="300" loading="lazy" />
      {!image && winnieImage && <span class="ai-tag">AI-rendered demo</span>}
    </div>
  )}
  <div class="badge">{bestFor}</div>
  <h3>{name}</h3>
  <p>{blurb}</p>
  {pros.length > 0 && (
    <ul class="pros">{pros.map((p) => <li>{p}</li>)}</ul>
  )}
  {cons.length > 0 && (
    <ul class="cons">{cons.map((c) => <li>{c}</li>)}</ul>
  )}
  <!-- Honest, uncloaked Amazon link. No price stated as fact. -->
  <a class="cta" href={link} rel="nofollow sponsored" target="_blank">Check price on Amazon →</a>
</article>

<!-- Styling lives in src/styles/global.css (.product-card, .badge, .pros, .cons, .cta)
     so every card on the site — roundups, product-page deep dives — looks consistent.
     Any AI-rendered Winnie/product image carries a small "AI-rendered demo" tag inline
     AND is covered by the fuller disclosure on the About page ("A note on Winnie's photos"). -->
