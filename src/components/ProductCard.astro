---
import {
  amazonLink,
  AMAZON_LINK_REL,
  isAmazonAssociatesApproved,
} from '../config.ts';
import LinkLevelDisclosure from './LinkLevelDisclosure.astro';

interface Props {
  name: string;
  asin: string;
  bestFor: string;
  blurb: string;
  pros?: string[];
  cons?: string[];
  lookFor?: string[];
  skipIf?: string[];
  smallSpaceNote?: string;
  image?: string;
  winnieImage?: string;
}
const {
  name,
  asin,
  bestFor,
  blurb,
  pros = [],
  cons = [],
  lookFor,
  skipIf,
  smallSpaceNote,
  image,
  winnieImage,
} = Astro.props;
const link = amazonLink(asin);
const photo = image ?? winnieImage;
const lookForItems = lookFor?.length ? lookFor : pros;
const skipItems = skipIf?.length ? skipIf : cons;
---
<article class="product-card">
  {photo && (
    <div class="product-card-photo">
      <img src={photo} alt={image ? name : `Winnie Hollowell setup for ${name}`} width="400" height="300" loading="lazy" />
    </div>
  )}
  <div class="badge">{bestFor}</div>
  <h3>{name}</h3>
  <p><strong>Why this fits:</strong> {blurb}</p>

  {lookForItems.length > 0 && (
    <div class="product-card-section">
      <p><strong>Look for:</strong></p>
      <ul class="pros">{lookForItems.map((p) => <li>{p}</li>)}</ul>
    </div>
  )}

  {skipItems.length > 0 && (
    <div class="product-card-section">
      <p><strong>Skip if:</strong></p>
      <ul class="cons">{skipItems.map((c) => <li>{c}</li>)}</ul>
    </div>
  )}

  <p class="small-space-note"><strong>Small-space note:</strong> {smallSpaceNote ?? 'Confirm the product dimensions, operating clearance, and storage location before ordering.'}</p>

  <a class="cta" href={link} rel={AMAZON_LINK_REL} target="_blank">
    {isAmazonAssociatesApproved ? 'Check current price on Amazon →' : 'View the current Amazon listing →'}
  </a>
  <LinkLevelDisclosure />
</article>

<style>
  .product-card-section > p { margin-bottom: 0.25rem; }
  .small-space-note { font-size: 0.9rem; }
</style>
