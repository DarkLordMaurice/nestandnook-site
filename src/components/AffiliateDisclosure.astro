---
// Renders BOTH required disclosures. Placed at the top of every content page by BaseLayout,
// before any affiliate link — this is what satisfies FTC + Amazon Operating Agreement.
import { DISCLOSURE } from '../config.ts';
---
<aside class="affiliate-disclosure" role="note">
  <p>{DISCLOSURE.ftc}</p>
  <p><em>{DISCLOSURE.associate}</em></p>
</aside>

<style>
  .affiliate-disclosure {
    background: #f6f6f4;
    border-left: 3px solid #c9a227;
    padding: 0.6rem 0.9rem;
    margin: 0 0 1.25rem;
    font-size: 0.85rem;
    color: #444;
    border-radius: 4px;
  }
  .affiliate-disclosure p { margin: 0.15rem 0; }
</style>
