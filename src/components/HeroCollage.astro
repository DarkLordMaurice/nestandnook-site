---
// Multi-photo hero treatment — replaces the old single small centered
// polaroid on hub/About/blog-index heroes. Renders every photo (anchor +
// accents) as a plain horizontal row, left to right, filling the full
// width of its container. No absolute positioning, no overlap math — a
// prior version tried an overlapping "corner accent" collage using
// position:absolute, which silently broke because `.polaroid`'s own
// `position: relative` was defined later in global.css and won the
// specificity tie, so the accents rendered in normal flow and stacked
// vertically like a filmstrip instead of overlapping. This version can't
// hit that bug because nothing here depends on absolute positioning.
interface Photo {
  src: string;
  alt: string;
  tilt?: 'left' | 'right';
  portrait?: boolean;
}
const { anchor, accents = [] } = Astro.props as {
  anchor: Photo;
  accents?: Photo[];
};
const photos = [anchor, ...accents];
// Tape color used to be hard-tied to tilt direction (tilt-right = teal,
// tilt-left = mustard) — since every collage call site alternates left/right
// in the same order, every hero collage on every page rendered the exact
// same mustard-teal-mustard (or teal-mustard-teal) pattern with zero real
// variation (Maurice, 2026-07-10: "the tape holding the photos is exactly
// the same color on all the pages"). Tilt still controls rotation angle;
// color now cycles independently through a 5-color pool keyed to the
// photo's position, so a 3-photo row shows 3 distinct colors instead of an
// ABA repeat, and different pages naturally land on different combinations.
const tapeColors = ['teal', 'hotpink', 'sage', 'mustard', 'gold'];
---
<div class="collage-row">
  {photos.map((p, i) => (
    <div class={`polaroid collage-photo tilt-${p.tilt ?? (i % 2 === 0 ? 'left' : 'right')} tape-${tapeColors[i % tapeColors.length]}`}>
      <img src={p.src} alt={p.alt} class={`collage-photo-img${p.portrait ? ' collage-photo-img-portrait' : ''}`} width="500" height="500" />
    </div>
  ))}
</div>
