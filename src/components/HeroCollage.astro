---
// Multi-photo hero treatment — replaces the old single small centered
// polaroid on hub/About/blog-index heroes. Renders every photo (anchor +
// accents) as a plain horizontal row, left to right, filling the full
// width of its container. No absolute positioning, no overlap math — a
// prior version tried an overlapping "corner accent" collage using
// position:absolute, which silently broke because `.polaroid`'s own
// `position: relative` was defined later in global.css and won the
// specificity tie, so the accents rendered in normal flow and stacked
// vertically like a filmstrip instead of overlapping. This version can't
// hit that bug because nothing here depends on absolute positioning.
interface Photo {
  src: string;
  alt: string;
  tilt?: 'left' | 'right';
  portrait?: boolean;
}
const { anchor, accents = [], seed = '' } = Astro.props as {
  anchor: Photo;
  accents?: Photo[];
  seed?: string;
};
const photos = [anchor, ...accents];

// Round 1 fix (earlier today) made tape color cycle across a 3-photo row
// instead of a hard-coded tilt-tied binary — but every call site still
// started that cycle at index 0 AND still passed an explicit `tilt` per
// photo, so every page's collage rendered the identical color+tilt sequence
// anyway (About: right/left/right, Blog/Recipes/both hubs: left/right/left
// — only 2 patterns existed site-wide). Maurice, 2026-07-10, second time:
// "they don't fucking rotate between pages... the colored tape is still
// exactly the same on each fucking page."
//
// Real fix: every call site now passes a distinct `seed` (page identity —
// 'about', 'blog', 'recipes', the hub slug, etc.) instead of hardcoding
// `tilt` per photo. The seed is hashed into a stable per-page offset that
// shifts BOTH the tilt-alternation start point and the tape-color start
// point, so each page's 3-photo row lands on a different combination —
// deterministic per page (same seed always renders the same way, so builds
// stay reproducible), but no longer identical across pages. Passing an
// explicit `tilt` on an individual photo still overrides the computed one,
// for the rare case a specific photo genuinely needs to force a direction.
function hashSeed(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
  return h;
}
const offset = hashSeed(seed);
const tapeColors = ['teal', 'hotpink', 'sage', 'mustard', 'gold'];
---
<div class="collage-row">
  {photos.map((p, i) => {
    const tilt = p.tilt ?? (((i + offset) % 2 === 0) ? 'left' : 'right');
    const tape = tapeColors[(i + offset) % tapeColors.length];
    return (
      <div class={`polaroid collage-photo tilt-${tilt} tape-${tape}`}>
        <img src={p.src} alt={p.alt} class={`collage-photo-img${p.portrait ? ' collage-photo-img-portrait' : ''}`} width="500" height="500" />
      </div>
    );
  })}
</div>
