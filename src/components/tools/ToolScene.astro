---
interface Props { slug: string; }
const { slug } = Astro.props;
const scenes = {
  'counter-footprint-simulator': { src: '/winnie/compact-air-fryer-counter-clearance-check.jpg', alt: 'Winnie measuring a compact counter appliance in a small kitchen.', caption: 'A real counter has edges, outlets, and a dinner routine. Start there.' },
  'desk-fit-reality-check': { src: '/winnie/winnie-office-small-desk-posture.jpg', alt: 'Winnie seated at a compact home-office desk with an ergonomic setup.', caption: 'Desk, chair, leg room, and foot support need to agree.' },
  'apartment-pet-zone-planner': { src: '/winnie/small-space-pet-care-setup-guide-scene1.jpg', alt: 'A compact apartment pet-care arrangement with daily zones separated.', caption: 'Small homes work better when each pet routine has its own address.' },
  'fold-away-workbench-fit-planner': { src: '/winnie/garage-workbench-car-clearance-check.jpg', alt: 'Winnie checking clearance between a fold-away workbench and a parked car.', caption: 'The open and folded garage both have to work.' },
}[slug];
---
<figure class={`tool-entry-scene tool-entry-scene--${slug}`}>
  <img src={scenes.src} alt={scenes.alt} width="960" height="420" loading="eager" />
  <figcaption>{scenes.caption}</figcaption>
</figure>
