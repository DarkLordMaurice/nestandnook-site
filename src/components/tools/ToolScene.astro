---
// PENDING support added 2026-07-16 for the 3 new tools shipped same day
// (why-doesnt-this-feel-done-yet, regret-proof-purchase-check, roast-my-space)
// — no real photo exists yet for any of them, and per the site's standing
// PENDING pattern (see WinniePendingPhoto.astro / HeroCollage.astro), a page
// ships now with a styled placeholder rather than waiting on image
// generation. Sized to this component's own 960x420 banner footprint, not
// borrowed from the smaller vertical hero-photo placeholder, to avoid the
// exact wrong-size-placeholder mistake documented in CLAUDE.md history.
interface Props { slug: string; }
const { slug } = Astro.props;
// 2026-07-17: these 4 "Technical" tools' images redone, matching the note
// in ToolCard.astro -- non-Winnie now, composed to show the checking/
// comparing action directly per Tool-Image-Legibility-Research-2026-07-17.md
// Parts 8/9. Captions unchanged -- none referenced Winnie directly.
const scenes = {
  'counter-footprint-simulator': { src: '/winnie/tool-hero-technical-counter-footprint-simulator.jpg', alt: 'A paper template with a dashed-line footprint outline laid on a kitchen counter at the counter edge.', caption: 'A real counter has edges, outlets, and a dinner routine. Start there.' },
  'desk-fit-reality-check': { src: '/winnie/tool-hero-technical-desk-fit-reality-check.jpg', alt: 'An office chair pulled up to a desk with a colored clearance mat visible on the floor underneath.', caption: 'Desk, chair, leg room, and foot support need to agree.' },
  'apartment-pet-zone-planner': { src: '/winnie/tool-hero-technical-apartment-pet-zone-planner.jpg', alt: 'An apartment floor plan with colored zone overlays and a small pet food bowl resting on one corner.', caption: 'Small homes work better when each pet routine has its own address.' },
  'fold-away-workbench-fit-planner': { src: '/winnie/tool-hero-technical-fold-away-workbench-fit-planner.jpg', alt: 'A fold-away workbench in a garage with its floor clearance marked in painter’s tape beside a parked car.', caption: 'The open and folded garage both have to work.' },
  // 2026-07-17 — see matching note in ToolCard.astro: these 5 tools
  // deliberately do NOT use Winnie. Composed per
  // Tool-Image-Legibility-Research-2026-07-17.md's legibility formula and
  // visually reviewed (image_review_manifest.json, batch
  // tool-hero-test-round2-2026-07-17). Captions unchanged from the PENDING
  // version -- none of them referenced Winnie directly, so they still read
  // correctly against the new non-Winnie imagery.
  'space-and-the-stars': { src: '/winnie/tool-hero-space-and-the-stars.jpg', alt: 'A zodiac wheel chart resting on a desk beside a small wooden house model and a brass key.', caption: 'Your space has always been written in the stars.' },
  'your-small-space-personality': { src: '/winnie/tool-hero-your-small-space-personality.jpg', alt: 'A multiple-choice quiz answer sheet with filled-in bubbles and a pencil resting on top.', caption: 'Six questions in, and you already know which drawer is yours.' },
  'why-doesnt-this-feel-done-yet': { src: '/winnie/tool-hero-why-doesnt-this-feel-done-yet.jpg', alt: 'An empty picture frame leaning against a wall below an empty picture hook.', caption: "It's rarely the whole room. It's usually one thing." },
  'regret-proof-purchase-check': { src: '/winnie/tool-hero-regret-proof-purchase-check.jpg', alt: 'A store receipt with lines circled and struck through in red pen, next to a handwritten shopping list.', caption: "The best purchase is sometimes the one you didn't make yet." },
  'roast-my-space': { src: '/winnie/tool-hero-roast-my-space.jpg', alt: 'An overflowing drawer stuffed with household items that will not fully close.', caption: "Every space has one spot it's not proud of. Show us yours." },
}[slug];
const isPending = scenes.src === 'PENDING';
const jokes = [
  "Winnie's camera-shy today — check back soon.",
  "This scene is still measuring itself for the perfect angle.",
  "Winnie insists this photo will happen on her schedule, not ours.",
];
const joke = jokes[Math.floor(Math.random() * jokes.length)];
---
{isPending ? (
  <figure class={`tool-entry-scene tool-entry-scene--${slug} tool-entry-scene-pending`}>
    <div class="tool-scene-pending-inner">
      <span class="tool-scene-pending-icon" aria-hidden="true">📸</span>
      <p class="tool-scene-pending-text">{joke}</p>
    </div>
    <figcaption>{scenes.caption}</figcaption>
  </figure>
) : (
  <figure class={`tool-entry-scene tool-entry-scene--${slug}`}>
    <img src={scenes.src} alt={scenes.alt} width="960" height="420" loading="eager" />
    <figcaption>{scenes.caption}</figcaption>
  </figure>
)}
<style>
  .tool-entry-scene-pending .tool-scene-pending-inner {
    width: 100%;
    aspect-ratio: 960 / 420;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, var(--color-accent-light, #eef2ff), var(--color-border, #e5e7eb));
    border-radius: 0.75rem;
    text-align: center;
    padding: 1.5rem;
  }
  .tool-scene-pending-icon { font-size: 2rem; }
  .tool-scene-pending-text { font-size: 0.95rem; font-style: italic; color: var(--color-text-muted, #6b7280); max-width: 28rem; }
</style>
