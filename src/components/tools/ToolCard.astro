---
import type { ToolDefinition } from '../../data/tools';
interface Props { tool: ToolDefinition; }
const { tool } = Astro.props;
// PENDING support added 2026-07-16 alongside the same fix in ToolScene.astro
// — this card-thumbnail lookup is a separate, parallel slug-keyed map from
// ToolScene's, and was missed on the first pass (caught by a real
// `npm run build` failure on /tools/, not by inspection — see
// Content-Run-Log.md-style verification discipline). Any new tool slug
// needs an entry here too, real or PENDING.
// 2026-07-17: these 4 "Technical" tools' images redone -- the originals
// (Winnie photography, predating the legibility research) depicted the
// general subject category (an appliance, an office, a pet area, a garage)
// rather than the tool's actual function of checking whether something
// fits/works. See Tool-Image-Legibility-Research-2026-07-17.md Part 8/9.
// Non-Winnie, same HF pipeline as the 5 Know-Yourself-First tools.
const artwork = {
  'counter-footprint-simulator': {
    src: '/winnie/tool-hero-technical-counter-footprint-simulator.jpg',
    alt: 'A paper template with a dashed-line footprint outline laid on a kitchen counter at the counter edge.',
  },
  'desk-fit-reality-check': {
    src: '/winnie/tool-hero-technical-desk-fit-reality-check.jpg',
    alt: 'An office chair pulled up to a desk with a colored clearance mat visible on the floor underneath.',
  },
  'apartment-pet-zone-planner': {
    src: '/winnie/tool-hero-technical-apartment-pet-zone-planner.jpg',
    alt: 'An apartment floor plan with colored zone overlays and a small pet food bowl resting on one corner.',
  },
  'fold-away-workbench-fit-planner': {
    src: '/winnie/tool-hero-technical-fold-away-workbench-fit-planner.jpg',
    alt: 'A fold-away workbench in a garage with its floor clearance marked in painter’s tape beside a parked car.',
  },
  // 2026-07-17: these 5 "Know yourself first" tools deliberately do NOT
  // use Winnie -- see Tool-Image-Legibility-Research-2026-07-17.md. Each is
  // a tool-themed, non-Winnie scene generated via the free Z-Image-Turbo
  // pipeline, composed per the legibility research (one dominant, familiar
  // real object + at most one reinforcing element, nothing competing) --
  // round 1 (Winnie-free but gut-feel composed) only worked for the receipt
  // image; round 2 applied the researched formula to the other 4 and all
  // passed visual review (image_review_manifest.json, batch
  // tool-hero-test-round2-2026-07-17).
  'space-and-the-stars': { src: '/winnie/tool-hero-space-and-the-stars.jpg', alt: 'A zodiac wheel chart resting on a desk beside a small wooden house model and a brass key.' },
  'your-small-space-personality': { src: '/winnie/tool-hero-your-small-space-personality.jpg', alt: 'A multiple-choice quiz answer sheet with filled-in bubbles and a pencil resting on top.' },
  'why-doesnt-this-feel-done-yet': { src: '/winnie/tool-hero-why-doesnt-this-feel-done-yet.jpg', alt: 'An empty picture frame leaning against a wall below an empty picture hook.' },
  'regret-proof-purchase-check': { src: '/winnie/tool-hero-regret-proof-purchase-check.jpg', alt: 'A store receipt with lines circled and struck through in red pen, next to a handwritten shopping list.' },
  'roast-my-space': { src: '/winnie/tool-hero-roast-my-space.jpg', alt: 'An overflowing drawer stuffed with household items that will not fully close.' },
}[tool.slug];
const isPending = artwork.src === 'PENDING';
---
<a class="tool-card" href={tool.href} data-tool-card data-category={tool.category}>
  <div class={`tool-card-art ${tool.slug}`}>
    {isPending ? (
      <div class="tool-card-art-pending" aria-hidden="true"><span>📸</span></div>
    ) : (
      <img src={artwork.src} alt={artwork.alt} width="640" height="480" loading="lazy" />
    )}
  </div>
  <div class="tool-card-copy"><span class="washi washi-teal">{tool.category}</span><h2>{tool.shortTitle}</h2><p>{tool.description}</p><span class="tool-card-link">Open tool <b aria-hidden="true">→</b></span></div>
</a>
<style>
  .tool-card-art-pending {
    width: 100%;
    aspect-ratio: 640 / 480;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-accent-light, #eef2ff), var(--color-border, #e5e7eb));
    font-size: 2rem;
  }
</style>
