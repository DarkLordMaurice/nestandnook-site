---
// Reusable "Winnie says" callout — the brand host's voice, visually set apart
// from the factual editorial content around it. Uses her real (photorealistic,
// virtual-spokesperson) avatar — see brand-assets/winnie/ for the source image
// and Brand-Guide.md §2 for the disclosure framing.
interface Props {
  signed?: boolean; // show "— Winnie" signature line at the end
}
const { signed = true } = Astro.props;
---
<aside class="winnie-note" role="note">
  <img src="/winnie/avatar.jpg" alt="Winnie Hollowell" class="avatar" width="44" height="44" />
  <div class="winnie-note-body">
    <slot />
    {signed && <span class="signed">— Winnie</span>}
  </div>
</aside>
